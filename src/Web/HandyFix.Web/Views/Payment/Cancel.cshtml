@model HandyFix.Web.ViewModels.Payment.PaymentCancelViewModel
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Payment Cancelled - HandyFix";
    var bookingId = Model.BookingId;
}

<div class="page-container payment-page-container">
    <div class="payment-status-card">
        <!-- Icon and Heading -->
        <div class="payment-status-icon-bubble">
            <span class="material-symbols-outlined payment-status-icon icon-medium-weight">warning</span>
        </div>
        <h1 class="payment-status-title">Payment Cancelled</h1>
        <p class="payment-status-desc">
            The secure Stripe checkout process was interrupted. No charges have been made to your account and your deposit was not processed.
        </p>

        <!-- Alert Box -->
        <div class="payment-status-alert">
            <span class="material-symbols-outlined payment-status-alert-icon">info</span>
            <div>
                <p class="payment-status-alert-title">Important Reminder</p>
                <p class="payment-status-alert-text">
                    To secure your chosen time slot and technician, a <span class="fw-bold text-primary">£50.00 deposit</span> is required. This amount will be deducted from your final bill once the job is complete.
                </p>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="payment-status-actions">
            @if (bookingId != null)
            {
                <a asp-controller="Payment" asp-action="Pay" asp-route-bookingId="@bookingId" class="btn btn-primary payment-status-btn" id="retry-btn">
                    <span class="material-symbols-outlined fs-20">refresh</span>
                    <span>Retry Payment (£50.00)</span>
                </a>
            }
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline payment-status-btn payment-status-btn-outline">
                Cancel and Return Home
            </a>
        </div>

        <!-- Security Note -->
        <div class="payment-status-security-note">
            <div class="security-note-item">
                <span class="material-symbols-outlined fs-14">lock</span>
                <span>Secure Stripe Checkout</span>
            </div>
            <div class="security-note-item">
                <span class="material-symbols-outlined fs-14">verified_user</span>
                <span>PCI Compliant</span>
            </div>
        </div>
    </div>
</div>

<p class="payment-help-text">
    Having trouble? <a asp-controller="Home" asp-action="Contact">Contact Support</a> or call 0800-HANDY-FIX
</p>

@section Scripts {
    <script>
        // Micro-interaction for the retry button loading state
        const retryBtn = document.getElementById('retry-btn');
        if (retryBtn) {
            retryBtn.addEventListener('click', function (e) {
                // Prevent immediate navigation so the user sees transition
                e.preventDefault();
                const targetHref = this.getAttribute('href');

                this.innerHTML = `
                    <svg class="animate-spin spinner-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Reconnecting to Stripe...</span>
                `;

                setTimeout(() => {
                    window.location.href = targetHref;
                }, 1000);
            });
        }
    </script>
}
