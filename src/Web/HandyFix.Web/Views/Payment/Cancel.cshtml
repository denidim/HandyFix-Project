@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Payment Cancelled - HandyFix";
    var bookingId = this.ViewData["BookingId"];
}

<div class="py-5 max-width-600 mx-auto text-center">
    <div class="cancel-icon-wrapper mb-4">
        <span class="display-3 text-danger">⚠️</span>
    </div>
    
    <h1 class="font-weight-bold text-slate">Payment Cancelled</h1>
    <p class="lead text-muted">The Stripe payment process was cancelled and your deposit has not been charged.</p>

    <div class="alert alert-warning py-3 px-4 rounded-lg my-4 text-left small leading-relaxed">
        To confirm your appointment and secure your scheduled time slot, a deposit payment of £50.00 is required. Unpaid bookings may be automatically cancelled.
    </div>

    <div class="d-flex justify-content-center gap-3 mt-4">
        @if (bookingId != null)
        {
            <a href="/Payment/Pay?bookingId=@bookingId" class="btn btn-primary px-4 py-2 font-weight-bold mr-2">Retry Payment (£50.00)</a>
        }
        <a href="/" class="btn btn-outline-secondary px-4 py-2 font-weight-bold">Cancel and Return Home</a>
    </div>
</div>
