@model HandyFix.Web.ViewModels.Services.ServiceDetailsViewModel
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = $"{Model.Name} - HandyFix South London";

    var isPlumbing = Model.CategoryName == "Plumbing";
    var durationHours = Model.EstimatedDurationMinutes >= 60 
        ? $"{(Model.EstimatedDurationMinutes / 60.0).ToString("0.#")} Hours" 
        : $"{Model.EstimatedDurationMinutes} Mins";

    // Dynamic Image path
    var serviceImage = Model.ImageUrl;

    // Feature dynamic data
    var feat1Icon = isPlumbing ? "faucet" : "shelves";
    var feat1Title = isPlumbing ? "Fixture Installations" : "Furniture Assembly";
    var feat1Desc = isPlumbing 
        ? "Expert installation of faucets, showerheads, and designer mixer taps with seamless finishing."
        : "Flat-pack furniture assembly, shelf mounting, and cabinets put together securely and efficiently.";

    var feat2Icon = isPlumbing ? "plumbing" : "build";
    var feat2Title = isPlumbing ? "Leak Detection" : "Home Repairs";
    var feat2Desc = isPlumbing 
        ? "Non-invasive thermal imaging and pressure testing to find and fix hidden leaks instantly."
        : "TV wall mounting, mirror hanging, door trimming, and general odd jobs handled by experts.";

    // Local Specialist dynamic data
    var expertName = isPlumbing ? "David" : "Mark";
    var expertRole = isPlumbing ? "Senior Plumber" : "Master Handyman";
    var expertBorough = isPlumbing ? "Sutton" : "Croydon";
    var expertBio = isPlumbing
        ? "I've spent 15 years servicing homes across Sutton, Croydon, and Epsom. I specialize in high-end bathroom remodels and precision leak detection."
        : "I've spent over 12 years helping homeowners with carpentry, mounting, and general property maintenance in Croydon and South London.";
}

<div class="page-container services-page">
    <!-- Hero Section -->
    <section class="service-hero-section">
        <div class="service-hero-image" style="background-image: url('@serviceImage')"></div>
        <div class="service-hero-overlay"></div>
        <div class="service-hero-content">
            <nav class="service-hero-breadcrumbs" aria-label="breadcrumb">
                <a asp-controller="Services" asp-action="Index">Services</a>
                <span class="material-symbols-outlined text-xs">chevron_right</span>
                <a asp-route="ServiceCategory" asp-route-categorySlug="@Model.CategorySlug">@Model.CategoryName</a>
                <span class="material-symbols-outlined text-xs">chevron_right</span>
                <span class="text-white">@Model.Name</span>
            </nav>
            <h1 class="service-hero-title">@Model.Name Specialists</h1>
            <div class="service-hero-badges">
                <span class="glass-card px-4 py-2 rounded-full text-white text-label-sm font-label-sm flex items-center gap-2">
                    <span class="material-symbols-outlined">verified</span> Professional Service
                </span>
                <span class="glass-card px-4 py-2 rounded-full text-white text-label-sm font-label-sm flex items-center gap-2">
                    <span class="material-symbols-outlined">schedule</span> 24/7 Available
                </span>
            </div>
        </div>
    </section>

    <!-- Main Layout Container -->
    <div class="service-details-layout">
        <!-- Main Content Area -->
        <main>
            <!-- Quick Specs Bento -->
            <div class="specs-bento-grid">
                <div class="spec-bento-card">
                    <span class="material-symbols-outlined spec-bento-icon">history</span>
                    <span class="spec-bento-label">Typical Duration</span>
                    <span class="spec-bento-value">@durationHours</span>
                </div>
                <div class="spec-bento-card">
                    <span class="material-symbols-outlined spec-bento-icon">category</span>
                    <span class="spec-bento-label">Service Category</span>
                    <span class="spec-bento-value">@Model.CategoryName</span>
                </div>
                <div class="spec-bento-card col-span-2">
                    <span class="material-symbols-outlined spec-bento-icon">payments</span>
                    <span class="spec-bento-label">Starting Price</span>
                    <span class="spec-bento-value">From £@Model.BasePrice.ToString("F0")</span>
                </div>
            </div>

            <!-- Detailed Description -->
            <section class="details-prose">
                <h2 class="details-section-title">Service Overview</h2>
                <p>@Model.Description</p>
                <p>At <strong>HandyFix</strong>, our mobile crews are specialized in @Model.Name operations. We come equipped with professional-grade tools, quality replacement components, and follow strict building codes to ensure a lasting repair or installation. All our work is fully insured for your peace of mind.</p>

                <div class="details-features-grid">
                    <div class="details-feature-item">
                        <div class="feature-item-icon-box">
                            <span class="material-symbols-outlined">@feat1Icon</span>
                        </div>
                        <div>
                            <h3 class="feature-item-title">@feat1Title</h3>
                            <p class="feature-item-desc">@feat1Desc</p>
                        </div>
                    </div>
                    <div class="details-feature-item">
                        <div class="feature-item-icon-box">
                            <span class="material-symbols-outlined">@feat2Icon</span>
                        </div>
                        <div>
                            <h3 class="feature-item-title">@feat2Title</h3>
                            <p class="feature-item-desc">@feat2Desc</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- FAQ Accordion -->
            <section class="faq-accordion-group">
                <h2 class="details-section-title">Frequently Asked Questions</h2>
                
                <details class="faq-accordion" open>
                    <summary class="faq-accordion-summary">
                        <span class="faq-accordion-title">How much does @Model.Name cost?</span>
                        <span class="material-symbols-outlined faq-accordion-icon">expand_more</span>
                    </summary>
                    <div class="faq-accordion-content">
                        Our base rate for @Model.Name starts from £@Model.BasePrice.ToString("F2"). The final cost depends on the complexity of the task and any additional materials or parts required. We always present transparent quotes before starting.
                    </div>
                </details>

                <details class="faq-accordion">
                    <summary class="faq-accordion-summary">
                        <span class="faq-accordion-title">Do you cover my location?</span>
                        <span class="material-symbols-outlined faq-accordion-icon">expand_more</span>
                    </summary>
                    <div class="faq-accordion-content">
                        We operate throughout Sutton, Croydon, Wimbledon, Mitcham, Epsom, Kingston, Bromley, and surrounding areas in South London, Surrey, and Kent.
                    </div>
                </details>

                <details class="faq-accordion">
                    <summary class="faq-accordion-summary">
                        <span class="faq-accordion-title">Is your @Model.Name service insured?</span>
                        <span class="material-symbols-outlined faq-accordion-icon">expand_more</span>
                    </summary>
                    <div class="faq-accordion-content">
                        Yes, absolutely. All HandyFix services, including @Model.Name, are fully backed by our £5M public liability insurance and 100% satisfaction guarantee.
                    </div>
                </details>
            </section>

            <!-- Local Expert Block -->
            <section class="local-expert-block">
                <div class="local-expert-avatar-wrapper">
                    <img class="local-expert-avatar" alt="@expertName - @expertRole" src="https://www.gstatic.com/labs-code/stitch/stitch-placeholder-300x300.svg">
                </div>
                <div>
                    <span class="local-expert-meta">Your Local Expert</span>
                    <h3 class="local-expert-name">Hi, I'm @expertName – @expertRole in @expertBorough</h3>
                    <p class="local-expert-bio">@expertBio I'm personally committed to making sure your property maintenance is completed to the highest standards.</p>
                    <div class="local-expert-stats">
                        <div class="local-expert-rating">
                            <span class="material-symbols-outlined icon-fill">star</span>
                            <span>4.9/5 Rating</span>
                        </div>
                        <span class="local-expert-divider">|</span>
                        <span class="local-expert-completed">Over 1,200 services completed</span>
                    </div>
                </div>
            </section>
        </main>

        <!-- Sidebar Area -->
        <aside>
            <div class="sidebar-sticky-wrapper">
                <!-- CTA Booking Card -->
                <div class="sidebar-booking-card">
                    <h3 class="sidebar-booking-title">Book This Service Now</h3>
                    <p class="sidebar-booking-desc">Expert technicians available in Sutton and surrounding areas. Fast, clean, and guaranteed.</p>
                    
                    <div class="sidebar-booking-features">
                        <div class="sidebar-booking-feature-item">
                            <span class="material-symbols-outlined sidebar-booking-feature-icon">check_circle</span>
                            <span>Transparent fixed pricing</span>
                        </div>
                        <div class="sidebar-booking-feature-item">
                            <span class="material-symbols-outlined sidebar-booking-feature-icon">check_circle</span>
                            <span>Certified master technicians</span>
                        </div>
                        <div class="sidebar-booking-feature-item">
                            <span class="material-symbols-outlined sidebar-booking-feature-icon">check_circle</span>
                            <span>Same-day service possible</span>
                        </div>
                    </div>

                    <a asp-controller="Booking" asp-action="Index" asp-route-serviceId="@Model.Id" class="sidebar-booking-btn">
                        <span>Request Your Booking</span>
                        <span class="material-symbols-outlined">arrow_forward</span>
                    </a>
                    <p class="sidebar-booking-note">No upfront payment required</p>
                </div>

                <!-- Trust Card -->
                <div class="sidebar-trust-box">
                    <h4 class="sidebar-trust-title">Why Handy Fix?</h4>
                    <div class="sidebar-trust-list">
                        <div class="sidebar-trust-item">
                            <span class="material-symbols-outlined sidebar-trust-icon">workspace_premium</span>
                            <div>
                                <p class="sidebar-trust-item-title">Fully Insured</p>
                                <p class="sidebar-trust-item-desc">Up to £5M public liability insurance.</p>
                            </div>
                        </div>
                        <div class="sidebar-trust-item">
                            <span class="material-symbols-outlined sidebar-trust-icon">health_and_safety</span>
                            <div>
                                <p class="sidebar-trust-item-title">Clean &amp; Tidy</p>
                                <p class="sidebar-trust-item-desc">We always wear shoe covers and clean up.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

<!-- JSON-LD Service schema structured data -->
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "Service",
  "serviceType": "@Model.Name",
  "provider": {
    "@@type": "LocalBusiness",
    "name": "HandyFix",
    "telephone": "07123456789",
    "priceRange": "$$",
    "address": {
      "@@type": "PostalAddress",
      "addressLocality": "Croydon",
      "addressRegion": "London",
      "addressCountry": "GB"
    }
  },
  "areaServed": [
    { "@@type": "AdministrativeArea", "name": "South London" },
    { "@@type": "AdministrativeArea", "name": "Sutton" },
    { "@@type": "AdministrativeArea", "name": "Croydon" },
    { "@@type": "AdministrativeArea", "name": "Epsom" },
    { "@@type": "AdministrativeArea", "name": "Kingston" },
    { "@@type": "AdministrativeArea", "name": "Bromley" }
  ],
  "offers": {
    "@@type": "Offer",
    "price": "@Model.BasePrice.ToString("F2")",
    "priceCurrency": "GBP"
  }
}
</script>

<!-- FAQ Schema -->
<script type="application/ld+json">
{
  "@@context": "https://schema.org",
  "@@type": "FAQPage",
  "mainEntity": [
    {
      "@@type": "Question",
      "name": "How much does @Model.Name cost?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "Our base rate for @Model.Name starts from £@Model.BasePrice.ToString("F2")."
      }
    },
    {
      "@@type": "Question",
      "name": "Do you cover my location?",
      "acceptedAnswer": {
        "@@type": "Answer",
        "text": "We operate throughout Sutton, Croydon, Wimbledon, Mitcham, Epsom, Kingston, Bromley, and surrounding areas in South London."
      }
    }
  ]
}
</script>
