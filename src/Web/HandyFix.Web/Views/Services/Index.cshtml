@model IEnumerable<HandyFix.Web.ViewModels.Services.CategoryViewModel>
@{
    this.ViewData["Title"] = "All Services - HandyFix South London";
}

<div class="py-4">
    <div class="text-center mb-5">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb justify-content-center bg-transparent p-0 mb-2">
                <li class="breadcrumb-item"><a href="/">Home</a></li>
                <li class="breadcrumb-item active" aria-current="page">Services</li>
            </ol>
        </nav>
        <h1 class="font-weight-bold text-slate">Our Professional Services</h1>
        <p class="lead text-muted">We provide professional, fully insured plumbing and handyman work across South London, Surrey, and Kent.</p>
    </div>

    <div class="row">
        @foreach (var category in this.Model)
        {
            <div class="col-lg-6 mb-4">
                <div class="card border-0 shadow-sm rounded-lg p-4 h-100 d-flex flex-column justify-content-between hover-grow">
                    <div>
                        <div class="d-flex align-items-center mb-3">
                            <span class="display-4 mr-3">@(category.Name == "Plumbing" ? "💧" : "🔨")</span>
                            <h2 class="font-weight-bold text-slate mb-0">@category.Name</h2>
                        </div>
                        <p class="text-muted leading-relaxed">@category.Description</p>
                    </div>
                    <div>
                        <hr class="my-4" />
                        <h5 class="font-weight-bold text-slate mb-3">Popular @category.Name Services:</h5>
                        <ul class="list-unstyled mb-4">
                            @foreach (var svc in category.Services.Take(5))
                            {
                                <li class="mb-2">
                                    <a href="/Services/@category.Slug/@svc.Slug" class="text-slate hover-primary d-flex justify-content-between align-items-center">
                                        <span>• @svc.Name</span>
                                        <span class="text-muted font-weight-bold">from £@svc.BasePrice.ToString("F2")</span>
                                    </a>
                                </li>
                            }
                        </ul>
                        <a href="/Services/@category.Slug" class="btn btn-primary btn-block w-100 font-weight-bold py-2">View All @category.Name Services</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
