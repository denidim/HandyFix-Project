@model HandyFix.Web.ViewModels.Booking.BookingInputModel
@using HandyFix.Web.ViewModels.Services
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Book Plumbing or Handyman Appointment - HandyFix London";
    var services = Model.Services;
    var dates = Model.AvailableDates;
    var selectedServiceId = Model.SelectedServiceId;
}

<div class="page-container booking-page">
    <div class="booking-layout">
        <!-- Left Column: Booking Wizard -->
        <div>
            <header class="booking-header">
                <h1 class="booking-title">Schedule Your Fix</h1>
                <p class="booking-subtitle">Professional help is just a few clicks away.</p>
            </header>

            <!-- Stepper -->
            <div class="stepper-container">
                <div class="step-indicator step-active" id="step-indicator-1">
                    <span class="step-bubble">1</span>
                    <span>Service &amp; Slot</span>
                </div>
                <div class="stepper-line"></div>
                <div class="step-indicator step-inactive" id="step-indicator-2">
                    <span class="step-bubble">2</span>
                    <span>Contact Info</span>
                </div>
                <div class="stepper-line"></div>
                <div class="step-indicator step-inactive" id="step-indicator-3">
                    <span class="step-bubble">3</span>
                    <span>Problem Details</span>
                </div>
            </div>

            <!-- Form Wizard -->
            <form asp-controller="Booking" asp-action="Index" method="post" enctype="multipart/form-data" id="booking-wizard-form">
                
                <!-- Step 1: Service & Scheduling -->
                <section class="form-step-section" id="step-1">
                    <div class="glass-card p-6 rounded-xl">
                        <h3 class="font-headline-sm text-headline-sm mb-4">Select Service Type</h3>
                        <div class="category-selection-grid">
                            <label class="cursor-pointer">
                                <input class="category-radio-input" name="service-category" type="radio" value="plumbing" checked>
                                <div class="category-radio-card">
                                    <span class="material-symbols-outlined category-radio-icon">plumbing</span>
                                    <span class="font-label-sm">Plumbing</span>
                                </div>
                            </label>
                            <label class="cursor-pointer">
                                <input class="category-radio-input" name="service-category" type="radio" value="handyman">
                                <div class="category-radio-card">
                                    <span class="material-symbols-outlined category-radio-icon">home_repair_service</span>
                                    <span class="font-label-sm">Handyman</span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="glass-card p-6 rounded-xl">
                        <h3 class="font-headline-sm text-headline-sm mb-4">Select Service</h3>
                        <div class="form-group">
                            <select asp-for="ServiceId" class="form-control" id="wizard-service" required>
                                <option value="">-- Select a Service --</option>
                                @foreach (var svc in services)
                                {
                                    <option value="@svc.Id" data-category="@svc.CategorySlug" data-price="@svc.BasePrice" data-duration="@svc.EstimatedDurationMinutes">
                                        @svc.Name (from £@svc.BasePrice)
                                    </option>
                                }
                            </select>
                            <span asp-validation-for="ServiceId" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="grid-2-col gap-6">
                        <!-- Date Picker -->
                        <div class="glass-card p-6 rounded-xl">
                            <h3 class="font-headline-sm text-headline-sm mb-4">Choose Date</h3>
                            <input class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary transition-all" 
                                   type="date" id="wizard-date" min="@DateTime.Today.ToString("yyyy-MM-dd")" required>
                        </div>

                        <!-- Time Slots -->
                        <div class="glass-card p-6 rounded-xl">
                            <h3 class="font-headline-sm text-headline-sm mb-4">Available Slots</h3>
                            <div id="wizard-slots-group" style="display:none;">
                                <div id="wizard-slots" class="slots-selector-grid">
                                    <!-- Populated by JS -->
                                </div>
                            </div>
                            <div id="slots-placeholder" class="text-center p-3 text-muted">
                                Select a date to view available time slots.
                            </div>
                            <span asp-validation-for="SlotId" class="text-danger small d-block mt-2"></span>
                            <input type="hidden" asp-for="SlotId" id="wizard-slot-id" required />
                        </div>
                    </div>
                </section>

                <!-- Step 2: Contact Info -->
                <section class="form-step-section hide-step" id="step-2">
                    <div class="glass-card p-8 rounded-xl space-y-6">
                        <h3 class="font-headline-sm text-headline-sm mb-4">Personal Details</h3>
                        <div class="grid-2-col gap-4">
                            <div class="form-group">
                                <label asp-for="CustomerFirstName" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">First Name</label>
                                <input asp-for="CustomerFirstName" class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary" placeholder="John" required />
                                <span asp-validation-for="CustomerFirstName" class="text-danger small"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="CustomerLastName" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">Last Name</label>
                                <input asp-for="CustomerLastName" class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary" placeholder="Doe" required />
                                <span asp-validation-for="CustomerLastName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="grid-2-col gap-4">
                            <div class="form-group">
                                <label asp-for="Email" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">Email Address</label>
                                <input asp-for="Email" class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary" type="email" placeholder="john.doe@example.com" required />
                                <span asp-validation-for="Email" class="text-danger small"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="PhoneNumber" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">Phone Number</label>
                                <input asp-for="PhoneNumber" class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary" type="tel" placeholder="07123456789" required />
                                <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="form-group">
                            <label asp-for="Address" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">Property Address</label>
                            <textarea asp-for="Address" class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary resize-none" placeholder="Full street address, city, postcode" rows="3" required></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>
                    </div>
                </section>

                <!-- Step 3: Problem Details -->
                <section class="form-step-section hide-step" id="step-3">
                    <div class="glass-card p-8 rounded-xl space-y-6">
                        <h3 class="font-headline-sm text-headline-sm mb-4">Describe the Issue</h3>
                        <div class="form-group">
                            <label asp-for="ProblemDescription" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">Problem Description</label>
                            <textarea asp-for="ProblemDescription" class="w-full border-border-subtle rounded-lg p-3 bg-white focus:ring-2 focus:ring-secondary/20 focus:border-secondary" placeholder="Please provide as much detail as possible about the repair needed..." rows="5" required></textarea>
                            <span asp-validation-for="ProblemDescription" class="text-danger small"></span>
                        </div>
                        <div class="form-group">
                            <label asp-for="Images" class="text-label-sm font-label-sm text-on-surface-variant mb-1 d-block">Upload Photos (Optional)</label>
                            <div class="upload-dropzone" onclick="document.getElementById('file-upload-input').click()">
                                <span class="material-symbols-outlined upload-icon">add_a_photo</span>
                                <p class="upload-text">Drag and drop images here or click to browse</p>
                                <span class="upload-hint">Supports JPG, PNG, WEBP (Max 15MB each, up to 5 photos). Auto-compressed.</span>
                                <input asp-for="Images" id="file-upload-input" style="display:none" type="file" multiple accept="image/jpeg,image/png,image/webp" data-max-files="5" data-max-size-mb="15" data-preview-grid="#booking-image-previews" />
                            </div>
                            <div id="booking-image-previews" class="image-preview-grid mt-3"></div>
                        </div>
                    </div>
                </section>

                <!-- Nav Buttons -->
                <div class="wizard-nav-buttons">
                    <button class="wizard-back-btn invisible" id="prev-btn" type="button">Back</button>
                    <button class="btn btn-primary" id="next-btn" type="button" style="padding: var(--spacing-3) var(--spacing-8);">Continue</button>
                    <button class="btn btn-success hide-step" id="submit-btn" type="submit" style="padding: var(--spacing-3) var(--spacing-8);" disabled>Proceed to Payment</button>
                </div>
            </form>
        </div>

        <!-- Right Column: Booking Summary -->
        <aside>
            <div class="sidebar-sticky-wrapper">
                <div class="summary-glow-card">
                    <h2 class="summary-title">Booking Summary</h2>
                    <div class="summary-list">
                        <div class="summary-row">
                            <span class="summary-label">Service</span>
                            <span class="summary-value" id="summary-service">--</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Date &amp; Time</span>
                            <span class="summary-value" id="summary-datetime">--</span>
                        </div>
                        <div class="summary-row">
                            <span class="summary-label">Call-out Fee</span>
                            <span class="summary-value">£35.00</span>
                        </div>
                        <div class="summary-row-total">
                            <span class="summary-label">Deposit Due Now</span>
                            <span class="summary-value" style="color: var(--secondary-container); font-weight: 700;">£50.00</span>
                        </div>
                    </div>
                    <div class="summary-price-container">
                        <div>
                            <p class="summary-total-label">Total Estimated</p>
                            <p class="summary-total-price" id="summary-total-price">£35.00</p>
                        </div>
                        <div class="summary-total-badge">Final price on-site</div>
                    </div>
                </div>
                
                <!-- Trust Badge -->
                <div class="sidebar-guarantee-card">
                    <div class="guarantee-icon-box">
                        <span class="material-symbols-outlined guarantee-icon" style="font-variation-settings: 'FILL' 1;">verified</span>
                    </div>
                    <div>
                        <p class="guarantee-title">Fixed Price Guarantee</p>
                        <p class="guarantee-desc">Your deposit is fully refundable if cancelled 24h before the appointment.</p>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let currentStep = 1;
            const totalSteps = 3;

            const nextBtn = document.getElementById('next-btn');
            const prevBtn = document.getElementById('prev-btn');
            const submitBtn = document.getElementById('submit-btn');
            const wizardForm = document.getElementById('booking-wizard-form');

            const serviceSelect = document.getElementById("wizard-service");
            const dateInput = document.getElementById("wizard-date");
            const slotsGroup = document.getElementById("wizard-slots-group");
            const slotsPlaceholder = document.getElementById("slots-placeholder");
            const slotsContainer = document.getElementById("wizard-slots");
            const hiddenSlotInput = document.getElementById("wizard-slot-id");
            const summaryService = document.getElementById("summary-service");
            const summaryDatetime = document.getElementById("summary-datetime");
            const summaryTotal = document.getElementById("summary-total-price");

            // Category Filter logic
            const categoryRadios = document.querySelectorAll('input[name="service-category"]');
            
            function filterServices() {
                const activeCategory = document.querySelector('input[name="service-category"]:checked').value;
                let firstMatch = null;
                
                Array.from(serviceSelect.options).forEach(opt => {
                    if (opt.value === "") {
                        opt.style.display = "";
                        return;
                    }
                    if (opt.dataset.category === activeCategory) {
                        opt.style.display = "";
                        if (!firstMatch) firstMatch = opt.value;
                    } else {
                        opt.style.display = "none";
                    }
                });
                
                // If current selection is hidden, reset it
                const selectedOption = serviceSelect.options[serviceSelect.selectedIndex];
                if (selectedOption && selectedOption.value !== "" && selectedOption.dataset.category !== activeCategory) {
                    serviceSelect.value = "";
                }
                
                // Preselect matching if serviceId was loaded via query param
                const selectedServiceId = '@selectedServiceId';
                if (selectedServiceId && selectedServiceId !== "") {
                    // Try to check matching category
                    const matchedOpt = Array.from(serviceSelect.options).find(o => o.value.toLowerCase() === selectedServiceId.toLowerCase());
                    if (matchedOpt) {
                        const targetCategory = matchedOpt.dataset.category;
                        const targetRadio = document.querySelector(`input[name="service-category"][value="${targetCategory}"]`);
                        if (targetRadio && !targetRadio.checked) {
                            targetRadio.checked = true;
                            filterServices(); // Re-run filter
                            return;
                        }
                        serviceSelect.value = matchedOpt.value;
                    }
                }
                
                updateSummaryPrice();
                checkFormValidity();
            }

            categoryRadios.forEach(radio => {
                radio.addEventListener('change', filterServices);
            });

            // Initial Filter
            filterServices();

            // Price Summary update
            function updateSummaryPrice() {
                const opt = serviceSelect.options[serviceSelect.selectedIndex];
                if (opt && opt.value !== "") {
                    const price = parseFloat(opt.dataset.price);
                    summaryService.textContent = opt.text.split(" (from")[0];
                    summaryTotal.textContent = "£" + (price + 35.00).toFixed(2); // Price + Callout fee
                } else {
                    summaryService.textContent = "--";
                    summaryTotal.textContent = "£35.00";
                }
                updateSummaryDateTime();
            }

            function updateSummaryDateTime() {
                const dateVal = dateInput.value;
                const slotBtn = document.querySelector(".slot-selection-btn.selected");
                
                if (dateVal && slotBtn) {
                    const formattedDate = new Date(dateVal).toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
                    summaryDatetime.textContent = `${formattedDate}, ${slotBtn.textContent}`;
                } else {
                    summaryDatetime.textContent = "--";
                }
            }

            serviceSelect.addEventListener("change", updateSummaryPrice);

            // Fetch time slots
            dateInput.addEventListener("change", function () {
                const selectedDate = dateInput.value;
                if (!selectedDate) {
                    slotsGroup.style.display = "none";
                    slotsPlaceholder.style.display = "block";
                    return;
                }

                slotsPlaceholder.style.display = "none";
                slotsContainer.innerHTML = "<div class='text-center p-3 text-muted w-100' style='grid-column: span 3;'>Loading slots...</div>";
                slotsGroup.style.display = "block";

                fetch(`/Booking/GetSlots?date=${selectedDate}`)
                    .then(res => {
                        if (!res.ok) throw new Error("Failed to load slots");
                        return res.json();
                    })
                    .then(slots => {
                        slotsContainer.innerHTML = "";
                        if (slots.length === 0) {
                            slotsContainer.innerHTML = "<div class='text-danger p-2 text-center w-100' style='grid-column: span 3;'>No slots available. Try another date.</div>";
                            return;
                        }

                        slots.forEach(slot => {
                            const button = document.createElement("button");
                            button.type = "button";
                            button.className = "slot-selection-btn";
                            button.textContent = slot.formattedTime;
                            button.dataset.id = slot.id;

                            button.addEventListener("click", function () {
                                document.querySelectorAll(".slot-selection-btn").forEach(b => b.classList.remove('selected'));
                                button.classList.add('selected');
                                hiddenSlotInput.value = slot.id;
                                updateSummaryDateTime();
                                checkFormValidity();
                            });

                            slotsContainer.appendChild(button);
                        });
                    })
                    .catch(err => {
                        console.error(err);
                        slotsContainer.innerHTML = "<div class='text-danger p-2 text-center w-100' style='grid-column: span 3;'>Error loading slots.</div>";
                    });
            });

            // Form Wizard flow control
            const updateUI = () => {
                for (let i = 1; i <= totalSteps; i++) {
                    const section = document.getElementById(`step-${i}`);
                    const indicator = document.getElementById(`step-indicator-${i}`);
                    
                    if (i === currentStep) {
                        section.classList.remove('hide-step');
                        indicator.className = "step-indicator step-active";
                    } else {
                        section.classList.add('hide-step');
                        indicator.className = "step-indicator step-inactive";
                    }
                }

                if (currentStep === 1) {
                    prevBtn.classList.add('invisible');
                } else {
                    prevBtn.classList.remove('invisible');
                }

                if (currentStep === totalSteps) {
                    nextBtn.classList.add('hide-step');
                    submitBtn.classList.remove('hide-step');
                } else {
                    nextBtn.classList.remove('hide-step');
                    submitBtn.classList.add('hide-step');
                }

                window.scrollTo({ top: 0, behavior: 'smooth' });
            };

            nextBtn.addEventListener('click', () => {
                if (currentStep < totalSteps) {
                    // Quick validation before advancing
                    if (currentStep === 1 && (!serviceSelect.value || !hiddenSlotInput.value)) {
                        alert("Please select a Service and an available Time Slot before continuing.");
                        return;
                    }
                    if (currentStep === 2) {
                        const firstName = document.getElementById("CustomerFirstName").value;
                        const lastName = document.getElementById("CustomerLastName").value;
                        const email = document.getElementById("Email").value;
                        const phone = document.getElementById("PhoneNumber").value;
                        const address = document.getElementById("Address").value;
                        if (!firstName || !lastName || !email || !phone || !address) {
                            alert("Please fill out all contact information fields.");
                            return;
                        }
                    }
                    currentStep++;
                    updateUI();
                }
            });

            prevBtn.addEventListener('click', () => {
                if (currentStep > 1) {
                    currentStep--;
                    updateUI();
                }
            });

            function checkFormValidity() {
                if (hiddenSlotInput.value && serviceSelect.value) {
                    submitBtn.disabled = false;
                } else {
                    submitBtn.disabled = true;
                }
            }

            serviceSelect.addEventListener("change", checkFormValidity);
        });
    </script>
    <script src="~/js/image-upload.js" asp-append-version="true"></script>
}
