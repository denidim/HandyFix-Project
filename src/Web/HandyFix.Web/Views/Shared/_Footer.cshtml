<footer class="footer-main">
    <div class="page-container footer-content">
        <div>
            <div class="font-display-brand text-white" style="margin-bottom: var(--spacing-6);">Handy Fix</div>
            <p class="text-white-80 font-body-md leading-relaxed" style="margin-bottom: var(--spacing-6);">
                Your trusted local partner for plumbing, maintenance, and handyman services across South London. Dedicated to quality and transparency.
            </p>
            <div class="footer-social">
                <a class="footer-social-icon" href="#">
                    <span class="material-symbols-outlined">share</span>
                </a>
                <a class="footer-social-icon" href="tel:07123456789">
                    <span class="material-symbols-outlined">phone</span>
                </a>
            </div>
        </div>
        <div class="footer-column">
            <h5 class="footer-title">Quick Links</h5>
            <a class="footer-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
            <a class="footer-link" asp-area="" asp-controller="Home" asp-action="Terms">Terms of Service</a>
            <a class="footer-link" asp-area="" asp-controller="Home" asp-action="FAQ">FAQ</a>
            <a class="footer-link" asp-area="" asp-controller="Home" asp-action="Contact">Contact</a>
            <a class="footer-link" asp-area="" asp-controller="Services" asp-action="Index">Services</a>
            <a class="footer-link" asp-area="" asp-controller="Home" asp-action="Reviews">Reviews</a>
            <a class="footer-link" href="#">Emergency Services</a>
        </div>
        <div>
            <h5 class="footer-title">Service Areas</h5>
            <div class="footer-areas-grid">
                <span>Sutton</span>
                <span>Croydon</span>
                <span>Epsom</span>
                <span>Wimbledon</span>
                <span>Kingston</span>
                <span>Richmond</span>
                <span>Mitcham</span>
                <span>Purley</span>
            </div>
            <div class="footer-copyright">
                <p>© @DateTime.Now.Year Handy Fix. All rights reserved.</p>
            </div>
        </div>
    </div>
</footer>
