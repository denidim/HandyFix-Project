@{
    this.Layout = "_Layout";
}

<div class="py-4 max-width-800 mx-auto text-slate">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-3">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Service Areas</li>
        </ol>
    </nav>

    <h1 class="font-weight-bold text-slate mb-4 text-center">Our Service Areas</h1>
    <p class="text-muted text-center mb-5">We cover boroughs across South London, Surrey borders, and West Kent.</p>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="p-3 border rounded h-100 bg-white shadow-sm">
                <h5 class="font-weight-bold text-primary mb-3">📍 South London</h5>
                <ul class="list-unstyled mb-0 text-muted small">
                    <li class="mb-1">Croydon</li>
                    <li class="mb-1">Wimbledon</li>
                    <li class="mb-1">Mitcham</li>
                    <li class="mb-1">Sutton</li>
                    <li class="mb-1">Carshalton</li>
                </ul>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-3 border rounded h-100 bg-white shadow-sm">
                <h5 class="font-weight-bold text-primary mb-3">📍 Surrey (Borders)</h5>
                <ul class="list-unstyled mb-0 text-muted small">
                    <li class="mb-1">Epsom</li>
                    <li class="mb-1">Kingston upon Thames</li>
                    <li class="mb-1">Richmond (Part)</li>
                    <li class="mb-1">Banstead</li>
                </ul>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="p-3 border rounded h-100 bg-white shadow-sm">
                <h5 class="font-weight-bold text-primary mb-3">📍 Kent &amp; Bromley</h5>
                <ul class="list-unstyled mb-0 text-muted small">
                    <li class="mb-1">Bromley</li>
                    <li class="mb-1">Orpington</li>
                    <li class="mb-1">Sevenoaks</li>
                    <li class="mb-1">Dartford</li>
                    <li class="mb-1">Maidstone</li>
                </ul>
            </div>
        </div>
    </div>

    <div class="bg-light p-4 rounded-lg border text-center mt-4">
        <h5 class="font-weight-bold text-slate">Don't see your area listed?</h5>
        <p class="text-muted small">If your postcode lies near the South London borders, our mobile teams can often still assist you. Send us an enquiry with your address.</p>
        <a href="/Contact" class="btn btn-outline-primary px-4 py-2 font-weight-bold mt-2">Get custom area quote</a>
    </div>
</div>
