@model HandyFix.Web.ViewModels.Home.HomeIndexViewModel
@{
    var categories = this.Model.Categories;
    var popularServices = this.Model.PopularServices;
    var reviews = this.Model.SliderReviews;
}

<!-- HERO SECTION -->
<section class="hero-section">
  <div class="hero-bg">
    <img src="~/images/hero.png" alt="Handy Fix Hero" width="2752" height="1536" fetchpriority="high">
    <div class="hero-bg-overlay"></div>
  </div>

  <div class="page-container hero-content">
    <div class="hero-grid">
      <div class="hero-text-content">
        <h1 class="font-headline-xl text-primary lh-tight mb-6">Local Plumbing & Handyman Services in South London</h1>
        <p class="font-body-lg text-text-main lh-relaxed mb-8">Reliable, professional, and fully insured mobile service operating in Sutton, Croydon, Epsom, and beyond. Booking has never been easier.</p>
        <div class="hero-value-props">
          <div class="value-prop-item">
            <span class="material-symbols-filled text-success font-bold">check_circle</span>
            <span class="font-button-text text-text-main">Fully Insured & Experienced Professionals</span>
          </div>
          <div class="value-prop-item">
            <span class="material-symbols-filled text-success font-bold">check_circle</span>
            <span class="font-button-text text-text-main">Transparent, Up-front Hourly Pricing</span>
          </div>
          <div class="value-prop-item">
            <span class="material-symbols-filled text-success font-bold">check_circle</span>
            <span class="font-button-text text-text-main">Fast Response & Local London Dispatch</span>
          </div>
          <div class="value-prop-item">
            <span class="material-symbols-filled text-success font-bold">check_circle</span>
            <span class="font-button-text text-text-main">100% Customer Satisfaction Guarantee</span>
          </div>
        </div>
        <a href="#services-overview" class="btn btn-primary btn-lg hero-cta-btn">Explore Our Services</a>
      </div>

      <div class="hero-booking-wrapper">
        <div class="glass-card hero-booking-card">
          <h3 class="font-headline-md text-primary mb-6">Check Availability</h3>
          <form id="hero-booking-form" method="get" asp-controller="Booking" asp-action="Index">
            <div class="mb-6">
              <label for="widget-category" class="form-label">Select Service</label>
              <select id="widget-category" name="categorySlug" class="form-control" required>
                <option value="">-- Choose a service --</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.Slug">@cat.Name (from £@cat.BasePrice/hr)</option>
                }
              </select>
            </div>
            <div class="mb-6">
              <label for="widget-date" class="form-label">Choose Date</label>
              <input type="date" id="widget-date" name="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
            </div>

            <!-- Informative Copy Block -->
            <div class="hero-note-box">
                <p class="font-label-sm text-on-tertiary-container mb-2 lh-normal">
                    <span class="fw-bold">Secure a visit at your convenient time</span><br>
                    by selecting a time slot & secure deposit on next page. No risk — cancel anytime.
                </p>
                <p class="font-label-sm text-on-tertiary-container m-0 lh-normal">
                    All jobs start with 1-hour base rate by category.
                    <a asp-route="Pricing" class="font-button-text hero-note-pricing-link">See Pricing &rarr;</a>
                </p>
            </div>

            <button type="submit" id="widget-submit-btn" class="btn btn-success btn-block hero-submit-btn" disabled>See Available Slots & Book &rarr;</button>
          </form>

          <div class="hero-quote-divider">
            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-primary btn-block d-flex align-items-center justify-content-center gap-2 hero-quote-btn">
              <span class="material-symbols-outlined">request_quote</span>
              <span>Get a Custom Quote</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Specialized Divisions -->
<section id="services-overview" class="section">
  <div class="page-container">
    <div class="section-header">
      <h2 class="font-headline-lg mb-4">
        <a asp-controller="Services" asp-action="Index" class="division-title-link">Specialized Divisions</a>
      </h2>
      <div class="section-header-divider"></div>
    </div>
    
    <div class="divisions-grid">
      <!-- Plumbing Division -->
      <div class="division-card">
        <div class="img-container">
          <img src="~/images/services/plumbing-category-hero.webp" alt="Plumbing" width="1024" height="1024" loading="lazy">
        </div>
        <div class="division-card-content">
          <div class="division-header-title">
            <span class="material-symbols-outlined text-secondary division-icon-lg">water_drop</span>
            <h3 class="font-headline-md m-0">Plumbing & Heating</h3>
          </div>
          <p class="text-text-main font-body-md mb-6 lh-relaxed">
            From emergency burst pipes to full boiler installations, our certified plumbers handle every drop with expert care and precision.
          </p>
          <ul class="division-services-list">
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Leak Detection</li>
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Boiler Service</li>
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Drainage Solutions</li>
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Tap Replacement</li>
          </ul>
          <a class="division-link" asp-route="ServiceCategory" asp-route-categorySlug="plumbing">
            View Plumbing Rates
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
      <!-- Handyman Division -->
      <div class="division-card">
        <div class="img-container">
          <img src="~/images/services/handyman-category-hero.webp" alt="Handyman" width="1024" height="1024" loading="lazy">
        </div>
        <div class="division-card-content">
          <div class="division-header-title">
            <span class="material-symbols-outlined text-secondary division-icon-lg">handyman</span>
            <h3 class="font-headline-md m-0">General Handyman</h3>
          </div>
          <p class="text-text-main font-body-md mb-6 lh-relaxed">
            Tackle your "to-do" list with professionals who specialize in efficiency. No job is too small for our expert property team.
          </p>
          <ul class="division-services-list">
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Furniture Assembly</li>
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>TV Mounting</li>
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Door Repairs</li>
            <li class="division-service-item"><span class="material-symbols-outlined text-secondary division-check-icon">check</span>Shelf Installation</li>
          </ul>
          <a class="division-link" asp-route="ServiceCategory" asp-route-categorySlug="handyman">
            View Handyman Rates
            <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Popular Services Bento Grid -->

<section class="section bg-surface">
    <div class="page-container">
        <div class="bento-header">
            <div class="section-header-left">
                <h2 class="font-headline-lg mb-2">
                    Popular Services
                </h2>

                <p class="text-text-main font-body-md m-0">
                    Most requested repairs and installations in South London
                </p>
            </div>

            <a asp-controller="Services" asp-action="Index" class="bento-see-all">See all services</a>
        </div>

        <div class="bento-grid-container">
            @foreach (var svc in Model.PopularServices)
            {

                <a class="bento-card"
                     asp-route="ServiceDetails"
                     asp-route-categorySlug="@svc.CategorySlug"
                     asp-route-serviceSlug="@svc.Slug">
                    <img src="@svc.ImageUrl"
                         alt="@svc.Name"
                         asp-append-version="true"
                         loading="lazy"
                         onerror="
                    this.onerror = null;
                    this.src = '/images/hero.png';
                    " />

                    <div class="bento-card-overlay"></div>

                    <div class="bento-card-content">
                        <h4 class="font-headline-md text-white">@svc.Name</h4>

                        <p class="text-white-80 font-body-md m-0">
                            From £@svc.BasePrice
                        </p>
                    </div>
                </a>

            }
        </div>
    </div>
</section>


<!-- Trust & Reliability -->
<section class="section">
  <div class="page-container">
    <div class="trust-grid">
      <div>
        <h2 class="font-headline-lg lh-tight mb-6">Trust Your Home to Qualified Experts</h2>
        <p class="font-body-lg text-text-main lh-relaxed mb-8">
          We don't just fix things; we provide peace of mind. Every member of the Handy Fix team undergoes rigorous background checks and technical vetting to ensure your property is in safe, capable hands.
        </p>
        <div class="trust-cards-list">
          <div class="trust-card">
            <div class="trust-card-icon">
              <span class="material-symbols-outlined">verified</span>
            </div>
            <div>
              <h4 class="font-headline-sm mb-1">Vetted Professionals</h4>
              <p class="text-on-surface-variant m-0">Thorough background checks and 5+ years experience required for all staff.</p>
            </div>
          </div>
          <div class="trust-card">
            <div class="trust-card-icon">
              <span class="material-symbols-outlined">payments</span>
            </div>
            <div>
              <h4 class="font-headline-sm mb-1">Transparent Flat Rates</h4>
              <p class="text-on-surface-variant m-0">No hidden fees, call-out charges, or surprise costs at the end of the job.</p>
            </div>
          </div>
          <div class="trust-card">
            <div class="trust-card-icon">
              <span class="material-symbols-outlined">shield_with_heart</span>
            </div>
            <div>
              <h4 class="font-headline-sm mb-1">Fully Insured</h4>
              <p class="text-on-surface-variant m-0">Up to £5M Public Liability insurance covering every single visit.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="trust-image-wrapper">
        <div class="blur-circle top-right"></div>
        <div class="blur-circle bottom-left"></div>
        <div class="glass-card trust-image-card">
          <img src="~/images/hero.png" alt="Trust" class="trust-hero-img" width="2752" height="1536" loading="lazy">
          <div class="trust-stats-card">
            <div class="trust-stats-col">
              <span class="font-bold text-primary">12k+ Jobs Completed</span>
              <div class="trust-stats-stars">
                <span class="material-symbols-filled">star</span>
                <span class="material-symbols-filled">star</span>
                <span class="material-symbols-filled">star</span>
                <span class="material-symbols-filled">star</span>
                <span class="material-symbols-filled">star</span>
              </div>
            </div>
            <div class="trust-stats-divider"></div>
            <div class="trust-stats-col">
              <span class="font-bold text-on-tertiary-container trust-stats-rating">4.9/5 Rating</span>
              <span class="text-on-surface-variant trust-stats-reviews">Based on 2,500 reviews</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Testimonials -->
<section class="section testimonials-section">
  <div class="testimonials-section-bg"></div>
  <div class="page-container testimonials-content-layer">
    <div class="section-header">
      <h2 class="font-headline-lg text-white mb-4">What Our Customers Say</h2>
      <p class="text-on-primary-container max-w-2xl mx-auto my-0">Real experiences from homeowners across Sutton, Croydon, and Epsom.</p>
      <div class="mt-4">
        <a asp-controller="Home" asp-action="Reviews" class="btn-testimonial-review">
          <span class="material-symbols-outlined testimonial-review-icon">rate_review</span>
          <span>Leave a Review</span>
        </a>
      </div>
    </div>
    
    <div class="testimonials-grid">
      @if (reviews.Any())
      {
          @foreach (var review in reviews)
          {
              <div class="testimonial-card">
                <div>
                  <div class="testimonial-stars">
                    @for (int i = 0; i < review.Rating; i++)
                    {
                        <span class="material-symbols-filled">star</span>
                    }
                  </div>
                  <p class="font-body-md text-white-90 italic mb-6 lh-relaxed">"@review.Comment"</p>
                </div>
                <div class="testimonial-author">
                  <div class="testimonial-avatar"></div>
                  <div>
                    <p class="font-bold text-white m-0">@review.CustomerName</p>
                    <p class="text-on-primary-container testimonial-role-label">Verified Client</p>
                  </div>
                </div>
              </div>
          }
      }
      else
      {
          <div class="testimonials-empty-state">
              No reviews yet. Be the first to leave a review!
          </div>
      }
    </div>
  </div>
</section>

<!-- Final CTA Section -->
<section class="section">
  <div class="page-container">
    <div class="cta-card">
      <div class="cta-card-bg"></div>
      <div class="cta-card-content">
        <h2 class="font-headline-xl mb-6">Ready to cross those repairs off your list?</h2>
        <p class="font-body-lg text-text-main cta-card-text">
          Join thousands of satisfied South London residents. Book your professional service in under 60 seconds.
        </p>
        <div class="cta-actions">
          <a asp-controller="Booking" asp-action="Index" class="btn btn-primary btn-lg cta-btn-primary-shadow">Book Appointment Now</a>
          <a asp-controller="Services" asp-action="Index" class="btn btn-outline-primary btn-lg cta-btn-outline-white">View All Services</a>
        </div>
        <div class="cta-benefits">
          <div class="cta-benefit-item"><span class="material-symbols-filled text-success">bolt</span>Same Day Available</div>
          <div class="cta-benefit-item"><span class="material-symbols-filled text-success">verified</span>Satisfaction Guaranteed</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Schema.org Local Business structured data -->
<script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "LocalBusiness",
      "name": "Handy Fix",
      "image": "https://handyfix.co.uk/images/logo.png",
      "@@id": "https://handyfix.co.uk",
      "url": "https://handyfix.co.uk",
      "telephone": "07123456789",
      "priceRange": "$$",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "South London Dispatch Office",
        "addressLocality": "Croydon",
        "addressRegion": "London",
        "postalCode": "CR0 1XX",
        "addressCountry": "GB"
      },
      "geo": {
        "@@type": "GeoCoordinates",
        "latitude": 51.3762,
        "longitude": -0.0982
      },
      "openingHoursSpecification": {
        "@@type": "OpeningHoursSpecification",
        "dayOfWeek": [
          "Monday",
          "Tuesday",
          "Wednesday",
          "Thursday",
          "Friday",
          "Saturday"
        ],
        "opens": "09:00",
        "closes": "17:00"
      },
      "sameAs": [
        "https://facebook.com/handyfixlondon",
        "https://twitter.com/handyfixlondon"
      ]
    }
</script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const observerOptions = {
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
            }
          });
        }, observerOptions);

        document.querySelectorAll('section').forEach(section => {
          section.style.transition = 'all 0.7s ease';
          section.style.opacity = '0';
          section.style.transform = 'translateY(2.5rem)';
          observer.observe(section);
        });
    });
</script>
