@{
    this.ViewData["Title"] = "Terms & Conditions - Handy Fix";
}

<div class="info-canvas mt-12">
    <!-- Hero Section for Terms -->
    <div class="text-center mb-5">
        <h1 class="font-headline-xl text-primary mb-2">Terms of Service</h1>
        <p class="font-body-lg text-on-surface-variant mb-1">Please read these terms carefully before booking our services.</p>
        <p class="font-label-sm text-on-surface-variant font-medium opacity-70 fs-12">Last updated: October 24, 2024</p>
    </div>

    <!-- Content Area -->
    <div class="info-card">
        <!-- 1. Services Provided -->
        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-filled text-secondary">plumbing</span>
                <h2>1. Services Provided</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-0">
                Handy Fix provides professional mobile plumbing and general handyman services. Our dedicated team of skilled technicians operates across a defined service territory to ensure timely and reliable property maintenance. We currently offer coverage in the following regions:
            </p>
            <ul class="d-flex flex-column gap-2 p-0 list-unstyled pl-4">
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-success mt-1 fs-16">check_circle</span>
                    <span><strong>South London:</strong> All major boroughs and residential districts.</span>
                </li>
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-success mt-1 fs-16">check_circle</span>
                    <span><strong>Surrey:</strong> Comprehensive coverage for suburban and rural properties.</span>
                </li>
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-success mt-1 fs-16">check_circle</span>
                    <span><strong>Kent:</strong> Extended service availability for the garden of England.</span>
                </li>
            </ul>
        </section>

        <hr class="info-section-divider" />

        <!-- 2. Booking & Payments -->
        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-filled text-secondary">payments</span>
                <h2>2. Booking Deposit &amp; Payments</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-2">
                To secure your service appointment, a mandatory booking deposit of <strong>£50.00</strong> is required at the time of scheduling. All deposits are processed securely via <strong>Stripe</strong>.
            </p>
            <p class="font-body-md text-on-surface-variant mb-0">
                The full amount of the deposit will be explicitly deducted from your final project invoice upon completion of the requested work. We accept all major credit cards and digital wallets through our secure payment gateway.
            </p>
        </section>

        <hr class="info-section-divider" />

        <!-- 3. Cancellations -->
        <section class="p-4 rounded-lg terms-cancellation-box">
            <div class="info-section-title-row mb-3">
                <span class="material-symbols-outlined text-secondary">event_busy</span>
                <h2>3. Cancellations &amp; Rescheduling</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-3">
                We understand that plans change. Our policy is designed to be fair to both our customers and our technicians:
            </p>
            <ul class="d-flex flex-column gap-2 p-0 list-unstyled">
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-success mt-1 fs-16">check_circle</span>
                    <span><strong>Standard Window:</strong> Cancellations or rescheduling requests made 24 hours or more prior to the appointment are free of charge. Your deposit will be fully refunded or transferred.</span>
                </li>
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-danger mt-1 fs-16">cancel</span>
                    <span><strong>Late Window:</strong> Any cancellation or rescheduling request made within 24 hours of the scheduled start time will result in the forfeiture of the £50.00 deposit.</span>
                </li>
            </ul>
        </section>

        <hr class="info-section-divider" />

        <!-- 4. User Obligations -->
        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-filled text-secondary">assignment_ind</span>
                <h2>4. User Obligations</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-2">
                As a user of Handy Fix services, you agree to the following responsibilities:
            </p>
            <ul class="d-flex flex-column gap-2 p-0 list-unstyled pl-4">
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-secondary mt-1 fs-16">arrow_right</span>
                    <span>Provide accurate and complete information regarding the scope of work and property location.</span>
                </li>
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-secondary mt-1 fs-16">arrow_right</span>
                    <span>Ensure safe and unobstructed access to the property at the scheduled appointment time.</span>
                </li>
                <li class="d-flex align-items-start gap-2">
                    <span class="material-symbols-outlined text-secondary mt-1 fs-16">arrow_right</span>
                    <span>Disclose any known hazardous conditions or unique property requirements prior to the technician's arrival.</span>
                </li>
            </ul>
        </section>

        <hr class="info-section-divider" />

        <!-- 5. Liability -->
        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-filled text-secondary">gavel</span>
                <h2>5. Liability &amp; Insurance</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-0">
                Handy Fix maintains comprehensive professional liability insurance. While we take every precaution to protect your property, our liability is limited to the direct costs of repair for damage caused by our gross negligence. We are not responsible for pre-existing structural issues, normal wear and tear, or indirect consequential losses.
            </p>
        </section>

        <hr class="info-section-divider" />

        <!-- Bottom Action -->
        <div class="pt-4 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 info-bottom-action">
            <div class="text-on-surface-variant font-body-md mb-0">
                Need a custom copy for your records?
            </div>
            <button class="btn btn-outline d-flex align-items-center gap-2 px-5 py-3 rounded-lg info-print-btn" onclick="window.print()">
                <span class="material-symbols-outlined">download</span>
                <span class="font-button-text">Download as PDF</span>
            </button>
        </div>
    </div>

    <!-- Additional Help -->
    <div class="info-help-box">
        <h3>Have questions?</h3>
        <p class="font-body-md text-on-surface-variant mb-3">Our support team is ready to clarify any part of these terms.</p>
        <a href="mailto:support@handyfix.com">support@handyfix.com</a>
    </div>
</div>
