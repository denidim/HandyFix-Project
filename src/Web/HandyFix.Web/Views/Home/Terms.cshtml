@{
    this.Layout = "_Layout";
}

<div class="py-4 max-width-800 mx-auto text-slate leading-relaxed">
    <h1 class="font-weight-bold text-slate mb-4">Terms and Conditions</h1>
    <p class="text-muted">Last updated: June 2026</p>

    <h3 class="font-weight-bold text-slate mt-4 h5">1. Services Provided</h3>
    <p class="text-muted small">Handy Fix provides mobile plumbing and handyman services to South London, Surrey, and Kent. All bookings are subject to availability and technician schedule dispatch.</p>

    <h3 class="font-weight-bold text-slate mt-4 h5">2. Booking Deposit Payments</h3>
    <p class="text-muted small">We charge a deposit fee of £50.00 to secure calendar bookings. Deposits are processed securely via Stripe. The deposit amount is fully deducted from the final invoice upon job completion.</p>

    <h3 class="font-weight-bold text-slate mt-4 h5">3. Cancellations &amp; Rescheduling</h3>
    <p class="text-muted small">Clients can cancel or reschedule appointments free of charge up to 24 hours prior to the scheduled start time. Cancellations inside 24 hours are subject to forfeiture of the £50.00 deposit.</p>
</div>
