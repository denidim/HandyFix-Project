@{
    this.ViewData["Title"] = "Privacy Policy - Handy Fix";
}

<!-- Hero Decorative Header -->
<div class="info-hero">
    <div class="info-hero-bg" style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuD6hvST1alGedZvXOKNjRUghiUWnYvrmDGOgaE2Rr5OUmbmodvMjS1mv_zo-FOmCbQQ2nJ5Ow9L-Rs3lLa8zbiDdj1RL9CBrCDcmla7NXUq18FzwNIItZG9DIoE3jg68r4RNBUNwcDowKGgv5kU_Y-h_wSMPrsS-XqoK2knIk-2YThHTUgVYbxVP5DPDIq1KydbcPtDMeqGAoYt-ioRFAS2Zl7vOKsgmt4dwFJqBDUpu2OV-iK1oqilhY0-KcJWqd5f2B18kiw1P6jp');"></div>
    <div class="info-hero-content">
        <h1 class="text-white font-headline-xl">Privacy Policy</h1>
        <p class="update-badge">Last Updated: June 15, 2024</p>
    </div>
</div>

<!-- Content Canvas -->
<div class="info-canvas">
    <!-- Main Content Card -->
    <div class="info-card">
        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">info</span>
                <h2>1. Introduction</h2>
            </div>
            <p class="font-body-lg text-on-surface-variant leading-relaxed">
                Welcome to Handy Fix. We are committed to protecting your personal data and your privacy. This Privacy Policy explains how we collect, use, and safeguard your information when you visit our website or use our professional maintenance services. By using our platform, you consent to the data practices described in this statement.
            </p>
        </section>

        <hr class="info-section-divider" />

        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">inventory_2</span>
                <h2>2. Information We Collect</h2>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="p-4 rounded-lg h-100" style="border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); background-color: var(--surface-container-low);">
                        <h3 class="font-headline-sm text-secondary mb-2" style="font-size: var(--fs-headline-sm);">Personal Information</h3>
                        <p class="text-on-surface-variant mb-0" style="font-size: 14px;">We collect names, email addresses, phone numbers, and physical service addresses to provide accurate quotes and facilitate on-site repairs.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 rounded-lg h-100" style="border-radius: var(--radius-lg); border: 1px solid var(--border-subtle); background-color: var(--surface-container-low);">
                        <h3 class="font-headline-sm text-secondary mb-2" style="font-size: var(--fs-headline-sm);">Usage Data</h3>
                        <p class="text-on-surface-variant mb-0" style="font-size: 14px;">We automatically collect information about your computer hardware and software, including IP addresses, browser types, and access times.</p>
                    </div>
                </div>
            </div>
        </section>

        <hr class="info-section-divider" />

        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">analytics</span>
                <h2>3. How We Use Information</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-3">
                Handy Fix collects and uses your personal information to operate its website(s) and deliver the services you have requested. We also use your information to:
            </p>
            <ul class="d-flex flex-column gap-2 p-0 list-unstyled">
                <li class="d-flex align-items-start gap-3">
                    <span class="material-symbols-outlined text-success mt-1" style="font-size: 18px;">check_circle</span>
                    <span>Verify your identity and process service requests.</span>
                </li>
                <li class="d-flex align-items-start gap-3">
                    <span class="material-symbols-outlined text-success mt-1" style="font-size: 18px;">check_circle</span>
                    <span>Communicate scheduled visits and technician arrivals.</span>
                </li>
                <li class="d-flex align-items-start gap-3">
                    <span class="material-symbols-outlined text-success mt-1" style="font-size: 18px;">check_circle</span>
                    <span>Improve our service quality and customer support experience.</span>
                </li>
            </ul>
        </section>

        <hr class="info-section-divider" />

        <!-- Featured Section: Data Security -->
        <section class="p-4 p-md-5 text-white rounded-xl" style="background-color: var(--primary-container); border-radius: var(--radius-xl);">
            <div class="d-flex align-items-center gap-3 mb-3">
                <span class="material-symbols-outlined text-secondary-container" style="font-variation-settings: 'FILL' 1;">security</span>
                <h2 class="font-headline-md text-white mb-0" style="font-size: var(--fs-headline-md);">4. Data Security &amp; Payments</h2>
            </div>
            <p class="font-body-lg opacity-90 leading-relaxed mb-4">
                We prioritize the security of your data. To ensure the highest level of protection for your financial information, we utilize **Stripe** for secure payment processing. 
            </p>
            <div class="p-4 rounded-lg d-flex flex-column flex-md-row align-items-center gap-4" style="background-color: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                <div class="flex-grow-1">
                    <p class="text-white font-bold mb-1" style="font-size: 13px; opacity: 0.8;">Payment Encryption</p>
                    <p class="mb-0 text-white" style="font-size: 13px; opacity: 0.9;">Handy Fix does not store credit card details on our servers. All transactional data is handled directly by Stripe's bank-grade encrypted infrastructure.</p>
                </div>
                <div class="font-bold text-white tracking-widest text-center" style="font-size: 18px; opacity: 0.7; border: 1.5px solid rgba(255,255,255,0.5); padding: 8px 16px; border-radius: 8px;">
                    STRIPE
                </div>
            </div>
        </section>

        <hr class="info-section-divider" />

        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">cookie</span>
                <h2>5. Cookies</h2>
            </div>
            <p class="font-body-md text-on-surface-variant mb-0">
                Our website uses "cookies" to help personalize your online experience. A cookie is a text file that is placed on your hard disk by a web page server. Cookies cannot be used to run programs or deliver viruses to your computer. You have the ability to accept or decline cookies through your browser settings.
            </p>
        </section>

        <hr class="info-section-divider" />

        <section class="info-section">
            <div class="info-section-title-row">
                <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">mail</span>
                <h2>6. Contact Us</h2>
            </div>
            <div class="p-4 rounded-lg" style="background-color: var(--surface-container); border-radius: var(--radius-lg);">
                <p class="font-body-md text-primary mb-4">
                    Handy Fix welcomes your questions or comments regarding this Privacy Policy. If you believe that Handy Fix has not adhered to this Statement, please contact us at:
                </p>
                <div style="display: flex; flex-direction: column; gap: var(--spacing-2);">
                    <p class="d-flex align-items-center gap-2 font-bold mb-0 text-primary" style="font-size: 14px;">
                        <span class="material-symbols-outlined text-secondary" style="font-size: 18px;">location_on</span>
                        <span>123 Repair Avenue, Suite 100, Fixit City, ST 54321</span>
                    </p>
                    <p class="d-flex align-items-center gap-2 text-secondary mb-0" style="font-size: 14px; font-weight: 700;">
                        <span class="material-symbols-outlined text-secondary" style="font-size: 18px;">alternate_email</span>
                        <span>support@handyfix.com</span>
                    </p>
                    <p class="d-flex align-items-center gap-2 mb-0 text-primary" style="font-size: 14px;">
                        <span class="material-symbols-outlined text-secondary" style="font-size: 18px;">call</span>
                        <span>+1 (555) HANDY-FIX</span>
                    </p>
                </div>
            </div>
        </section>
    </div>

    <!-- Download PDF Button -->
    <div class="mt-4 d-flex justify-content-center">
        <button onclick="window.print()" class="btn btn-outline d-flex align-items-center gap-2 px-5 py-3" style="border: 1px solid var(--border-subtle); border-radius: var(--radius-full); background: #ffffff; color: var(--text-main);">
            <span class="material-symbols-outlined">download</span>
            <span class="font-button-text">Download as PDF</span>
        </button>
    </div>
</div>
