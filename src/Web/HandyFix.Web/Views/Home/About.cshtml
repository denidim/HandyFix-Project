@{
    this.Layout = "_Layout";
}

<div class="py-4 max-width-800 mx-auto text-slate">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-3">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">About Us</li>
        </ol>
    </nav>

    <h1 class="font-weight-bold text-slate mb-4">About Handy Fix</h1>
    
    <div class="leading-relaxed text-muted mb-4" style="font-size: 1.1rem;">
        <p>Handy Fix was founded on a simple premise: home repairs and maintenance should be reliable, professional, and transparent. Operating from our dispatch office in Croydon, we provide specialized mobile plumbing and handyman services to homeowners, tenants, and landlords throughout South London, Surrey, and Kent.</p>
        
        <p>Unlike generic platforms, we employ certified, vetted, and background-checked technicians. Every team member brings years of on-the-job experience and arrives equipped with high-quality components and tools to get the task done right the first time.</p>
    </div>

    <h3 class="font-weight-bold text-slate mt-5 mb-3">Our Core Business Values</h3>
    <div class="row">
        <div class="col-md-6 mb-3">
            <div class="p-3 border rounded h-100 bg-white">
                <h5 class="font-weight-bold text-primary">✓ Transparent Pricing</h5>
                <p class="text-muted small mb-0">We believe in complete pricing clarity. That's why we specify base rates and provide full quotes upfront before starting any physical work.</p>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="p-3 border rounded h-100 bg-white">
                <h5 class="font-weight-bold text-primary">✓ Guaranteed Satisfaction</h5>
                <p class="text-muted small mb-0">If you are not completely satisfied with our plumbing or handyman services, we will return to fix it, free of charge. Your peace of mind is our priority.</p>
            </div>
        </div>
    </div>
</div>
