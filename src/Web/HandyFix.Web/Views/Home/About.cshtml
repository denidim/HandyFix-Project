@{
    this.ViewData["Title"] = "About Us - Handy Fix";
}

<!-- Hero Section -->
<section class="about-hero mt-12">
    <span class="about-hero-tag">Crafting Quality Since 2018</span>
    <h1 class="font-headline-xl text-primary mb-3">Precision Repairs, <br><span class="text-secondary">Reliable Solutions.</span></h1>
    <p class="font-body-lg text-on-surface-variant max-w-2xl mx-auto mb-4">
        Handy Fix provides the technical expertise and transparent service Croydon homeowners trust for high-end plumbing and maintenance.
    </p>
    <div class="d-flex gap-3 justify-content-center">
        <a href="#our-story" class="btn btn-primary px-4 py-3 rounded-lg fw-semibold">Our Story</a>
        <a asp-controller="Services" asp-action="Index" class="btn btn-outline px-4 py-3 rounded-lg fw-semibold info-print-btn">View Services</a>
    </div>
</section>

<!-- The Croydon Narrative Section -->
<section id="our-story" class="info-canvas mb-16">
    <div class="narrative-grid">
        <div class="position-relative">
            <div class="narrative-image-wrapper">
                <img src="~/images/hero.png" alt="Handy Fix professional technician performing precision plumbing repairs" width="2752" height="1536" loading="lazy" />
            </div>
            <div class="narrative-badge">
                <p class="font-headline-sm text-secondary mb-1 italic fs-16 fw-semibold">"We fix it right, the first time."</p>
                <p class="text-muted mb-0 fs-11">— Founder's Promise</p>
            </div>
        </div>
        <div>
            <h2 class="font-headline-lg text-primary mb-3">Rooted in <span class="text-secondary">Croydon.</span></h2>
            <p class="font-body-lg text-on-surface-variant mb-3 lh-24">
                Handy Fix was born in the heart of Croydon from a simple observation: homeowners deserved more than just a quick fix. They deserved a partner who values their property as much as they do.
            </p>
            <p class="font-body-md text-on-surface-variant mb-4">
                Starting with a single van and a set of precision tools, we've grown into South London's premier mobile maintenance service. Our focus has never wavered: delivering high-fidelity plumbing and handyman solutions with the technical competence of an engineer and the care of a local neighbor.
            </p>
            <div class="narrative-stats">
                <div class="narrative-stat-pill">
                    <span class="stat-num">5,000+</span>
                    <span class="text-muted fs-12 fw-semibold">Successful Fixes</span>
                </div>
                <div class="narrative-stat-pill">
                    <span class="stat-num">15+</span>
                    <span class="text-muted fs-12 fw-semibold">Specialist Techs</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Core Values Section -->
<section class="guarantees-section">
    <div class="max-w-7xl mx-auto text-center mb-5">
        <h2 class="font-headline-lg text-primary mb-2">Our Core <span class="text-secondary">Guarantees</span></h2>
        <p class="font-body-md text-on-surface-variant max-w-xl mx-auto mb-0">We've built our reputation on three unbreakable pillars that ensure every client feels assured and respected.</p>
    </div>
    <div class="guarantees-grid">
        <!-- Guarantee 1 -->
        <div class="guarantee-card">
            <div class="guarantee-icon-box">
                <span class="material-symbols-outlined">payments</span>
            </div>
            <h3 class="font-headline-sm text-primary mb-2 fs-18 fw-bold">Transparent Pricing</h3>
            <p class="font-body-md text-on-surface-variant mb-0 fs-14">
                No hidden fees, no surprise surcharges. We provide detailed digital quotes before any work begins, ensuring complete financial clarity for every project.
            </p>
        </div>
        <!-- Guarantee 2 -->
        <div class="guarantee-card">
            <div class="guarantee-icon-box">
                <span class="material-symbols-outlined">verified</span>
            </div>
            <h3 class="font-headline-sm text-primary mb-2 fs-18 fw-bold">Guaranteed Satisfaction</h3>
            <p class="font-body-md text-on-surface-variant mb-0 fs-14">
                Our work isn't done until you're satisfied. We stand by every repair with a comprehensive 12-month workmanship guarantee for your peace of mind.
            </p>
        </div>
        <!-- Guarantee 3 -->
        <div class="guarantee-card">
            <div class="guarantee-icon-box">
                <span class="material-symbols-outlined">sensors</span>
            </div>
            <h3 class="font-headline-sm text-primary mb-2 fs-18 fw-bold">Rapid Deployment</h3>
            <p class="font-body-md text-on-surface-variant mb-0 fs-14">
                Our mobile-first fleet is strategically stationed throughout Croydon and Greater London to ensure we reach your doorstep precisely when you need us.
            </p>
        </div>
    </div>
</section>

<!-- CTA Section with Specialty Treatment -->
<section class="info-canvas mb-16">
    <div class="about-cta-card">
        <div class="about-cta-card-pattern"></div>
        <div class="d-flex flex-column flex-md-row align-items-center gap-4 position-relative z-1">
            <div class="flex-grow-1">
                <h2 class="font-headline-lg text-primary mb-3">Ready for a <span class="text-secondary">Seamless</span> Repair?</h2>
                <p class="font-body-lg text-on-surface-variant mb-4">Book your specialist technician in under 2 minutes with our streamlined digital booking system.</p>
                <div class="d-flex flex-wrap gap-4">
                    <div class="d-flex align-items-center gap-2 text-on-surface-variant fs-12 fw-semibold">
                        <span class="material-symbols-outlined text-secondary fs-16">check_circle</span>
                        <span>Instant Quotes</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 text-on-surface-variant fs-12 fw-semibold">
                        <span class="material-symbols-outlined text-secondary fs-16">check_circle</span>
                        <span>Same-Day Service</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 text-on-surface-variant fs-12 fw-semibold">
                        <span class="material-symbols-outlined text-secondary fs-16">check_circle</span>
                        <span>Fully Insured</span>
                    </div>
                </div>
            </div>
            <div class="flex-shrink-0 mt-4 mt-md-0">
                <a asp-controller="Booking" asp-action="Index" class="btn btn-secondary px-5 py-3 d-flex align-items-center gap-2 shadow-sm rounded-lg fs-16 fw-semibold text-white">
                    <span class="material-symbols-outlined">calendar_month</span>
                    <span>Book Now</span>
                </a>
            </div>
        </div>
    </div>
</section>
