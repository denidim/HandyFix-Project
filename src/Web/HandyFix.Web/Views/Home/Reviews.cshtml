@model HandyFix.Web.ViewModels.Reviews.ReviewsListViewModel
@{
    this.ViewData["Title"] = "Customer Reviews - Handy Fix";
}

<div class="info-canvas" style="margin-top: var(--spacing-12); margin-bottom: var(--spacing-12);">
    <!-- Hero Section -->
    <section class="mb-5 text-center text-md-start">
        <h1 class="font-headline-xl text-primary mb-2">What Our Clients Say</h1>
        <p class="font-body-lg text-on-surface-variant max-w-2xl">
            Discover why thousands of homeowners trust Handy Fix for their maintenance needs. Verified reviews from our community.
        </p>
    </section>

    @if (this.TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success p-3 rounded-lg mb-4 text-center" style="border-radius: var(--radius-lg);">
            @this.TempData["SuccessMessage"]
        </div>
    }

    <div class="reviews-container">
        <!-- Sidebar: Review Form -->
        <aside class="order-2 order-lg-1">
            <div class="glass-card rounded-xl p-4 sticky-top" style="top: 100px; border-radius: var(--radius-xl);">
                <h2 class="font-headline-md text-primary mb-4" style="font-size: var(--fs-headline-md);">Submit Your Review</h2>
                
                <form asp-controller="Reviews" asp-action="Submit" method="post" class="d-flex flex-column gap-3" id="reviewForm">
                    <div class="form-field">
                        <label asp-for="NewReview.CustomerName" class="form-label" style="font-weight: 600;">Full Name</label>
                        <input asp-for="NewReview.CustomerName" name="CustomerName" class="form-control" placeholder="John Doe" required />
                        <span asp-validation-for="NewReview.CustomerName" class="validation-error"></span>
                    </div>

                    <div class="form-field">
                        <label class="form-label" style="font-weight: 600;">Rating</label>
                        <div class="rating-selector-buttons" id="ratingSelector">
                            <button class="material-symbols-outlined star-btn" data-value="1" type="button">star</button>
                            <button class="material-symbols-outlined star-btn" data-value="2" type="button">star</button>
                            <button class="material-symbols-outlined star-btn" data-value="3" type="button">star</button>
                            <button class="material-symbols-outlined star-btn" data-value="4" type="button">star</button>
                            <button class="material-symbols-outlined star-btn" data-value="5" type="button">star</button>
                        </div>
                        <!-- Hidden Select to bind into Model -->
                        <select asp-for="NewReview.Rating" name="Rating" id="hiddenRating" class="d-none" required>
                            <option value="">Select rating</option>
                            <option value="1">1</option>
                            <option value="2">2</option>
                            <option value="3">3</option>
                            <option value="4">4</option>
                            <option value="5">5</option>
                        </select>
                        <span asp-validation-for="NewReview.Rating" class="validation-error"></span>
                    </div>

                    <div class="form-field">
                        <label asp-for="NewReview.Comment" class="form-label" style="font-weight: 600;">Your Experience</label>
                        <textarea asp-for="NewReview.Comment" name="Comment" class="form-control" rows="4" placeholder="How was your booking experience or service repair?" required style="resize: none;"></textarea>
                        <span asp-validation-for="NewReview.Comment" class="validation-error"></span>
                    </div>

                    <div class="pt-2">
                        <button class="btn btn-primary btn-block py-3 d-flex align-items-center justify-content-center gap-2" type="submit" style="border-radius: var(--radius-lg); font-size: 16px; font-weight: 600;">
                            <span>Post Review</span>
                            <span class="material-symbols-outlined">send</span>
                        </button>
                    </div>
                </form>

                <div class="mt-4 pt-4 border-t border-border-subtle" style="border-top: 1px solid var(--border-subtle);">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-light p-2 rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: rgba(0, 150, 104, 0.08) !important;">
                            <span class="material-symbols-outlined text-secondary">verified</span>
                        </div>
                        <div>
                            <p class="font-label-sm text-primary mb-0" style="font-weight: 600;">Trust &amp; Safety</p>
                            <p class="text-muted mb-0" style="font-size: 11px;">Every review is manually verified by our support team.</p>
                        </div>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Feed: Testimonials -->
        <main class="order-1 order-lg-2">
            <!-- Stat Overview -->
            <div class="stat-overview-row">
                <div class="stat-overview-pill">
                    <span class="num-highlight">4.9</span>
                    <div>
                        <div class="d-flex text-warning">
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;">star</span>
                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 18px;">star</span>
                        </div>
                        <p class="text-muted mb-0" style="font-size: 12px; font-weight: 600;">Global Satisfaction</p>
                    </div>
                </div>
                <div class="stat-overview-pill">
                    <span class="num-highlight">2.4k</span>
                    <div>
                        <p class="text-primary mb-0" style="font-size: 14px; font-weight: 700;">Verified Reviews</p>
                        <p class="text-muted mb-0" style="font-size: 11px;">Updated today</p>
                    </div>
                </div>
            </div>

            <!-- Testimonial List -->
            <div class="review-feed">
                @if (Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <!-- Card -->
                        <article class="review-card">
                            <div class="review-author-row">
                                <div class="review-author-info">
                                    <div class="review-avatar">
                                        @if (!string.IsNullOrEmpty(review.CustomerName) && review.CustomerName.Length >= 2)
                                        {
                                            <span>@review.CustomerName.Substring(0, 2).ToUpper()</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined">person</span>
                                        }
                                    </div>
                                    <div>
                                        <h3 class="font-headline-sm text-primary mb-0" style="font-size: 16px; font-weight: 700;">@review.CustomerName</h3>
                                        <p class="text-muted mb-0" style="font-size: 12px;">Client Review</p>
                                    </div>
                                </div>
                                <div class="text-warning d-flex">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= review.Rating)
                                        {
                                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1; font-size: 20px;">star</span>
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0; font-size: 20px;">star</span>
                                        }
                                    }
                                </div>
                            </div>
                            <p class="font-body-md text-on-surface mb-3" style="line-height: var(--lh-body-md);">
                                "@review.Comment"
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="verified-badge">
                                    <span class="material-symbols-outlined" style="font-size: 14px;">verified_user</span>
                                    <span>Verified Client</span>
                                </div>
                                <small class="text-muted" style="font-size: 11px;">@review.CreatedOn.ToString("dd MMM yyyy")</small>
                            </div>
                        </article>
                    }
                }
                else
                {
                    <div class="text-center p-5 text-muted bg-light rounded-xl" style="border: 2px dashed var(--outline-variant); border-radius: var(--radius-xl);">
                        <span class="material-symbols-outlined text-muted mb-2" style="font-size: 36px;">rate_review</span>
                        <p class="mb-0">No reviews published yet. Be the first to share your experience!</p>
                    </div>
                }
            </div>
        </main>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const stars = document.querySelectorAll('#ratingSelector .star-btn');
        const hiddenRating = document.getElementById('hiddenRating');

        stars.forEach((star, index) => {
            star.addEventListener('click', () => {
                const ratingValue = index + 1;
                hiddenRating.value = ratingValue;

                // Update visual styles
                stars.forEach((s, i) => {
                    if (i < ratingValue) {
                        s.classList.add('star-active');
                        s.style.fontVariationSettings = "'FILL' 1";
                    } else {
                        s.classList.remove('star-active');
                        s.style.fontVariationSettings = "'FILL' 0";
                    }
                });
            });
        });
    </script>
}
