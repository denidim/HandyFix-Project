@model HandyFix.Web.ViewModels.Reviews.ReviewsListViewModel
@{
    this.Layout = "_Layout";
}

<div class="py-4 max-width-800 mx-auto text-slate">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-transparent p-0 mb-3">
            <li class="breadcrumb-item"><a href="/">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Reviews</li>
        </ol>
    </nav>

    <h1 class="font-weight-bold text-slate mb-4 text-center">Customer Testimonials</h1>

    @if (this.TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success p-3 rounded-lg mb-4 text-center">
            @this.TempData["SuccessMessage"]
        </div>
    }

    <div class="row">
        <!-- Reviews List -->
        <div class="col-lg-7">
            <h3 class="font-weight-bold mb-3 h4">Recent Client Reviews</h3>
            @if (Model.Reviews.Any())
            {
                @foreach (var review in Model.Reviews)
                {
                    <div class="card p-3 border mb-3 rounded shadow-sm bg-white">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="font-weight-bold text-slate">@review.CustomerName</span>
                            <span class="text-warning small">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <span>★</span>
                                }
                            </span>
                        </div>
                        <p class="text-muted small mb-1">"@review.Comment"</p>
                        <small class="text-muted-light block text-right font-italic" style="font-size: 0.75rem;">@review.CreatedOn.ToString("dd MMM yyyy")</small>
                    </div>
                }
            }
            else
            {
                <div class="text-center p-4 text-muted border border-dashed rounded bg-light">
                    No reviews published yet. Be the first to tell us how we did!
                </div>
            }
        </div>

        <!-- Add Review Form -->
        <div class="col-lg-5 mt-4 mt-lg-0">
            <div class="card shadow-sm border p-4 bg-white sticky-top" style="top: 2rem;">
                <h4 class="font-weight-bold mb-3 h5">Submit Your Review</h4>
                <form asp-controller="Reviews" asp-action="Submit" method="post">
                    <div class="form-group mb-3">
                        <label asp-for="NewReview.CustomerName" class="form-label font-weight-bold small">Your Name</label>
                        <input asp-for="NewReview.CustomerName" name="CustomerName" class="form-control" placeholder="e.g. Jane Smith" required />
                        <span asp-validation-for="NewReview.CustomerName" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="NewReview.Comment" class="form-label font-weight-bold small">Your Review</label>
                        <textarea asp-for="NewReview.Comment" name="Comment" class="form-control" rows="4" placeholder="How was your booking experience or service repair?" required></textarea>
                        <span asp-validation-for="NewReview.Comment" class="text-danger small"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="NewReview.Rating" class="form-label font-weight-bold small">Rating</label>
                        <select asp-for="NewReview.Rating" name="Rating" class="form-control" required>
                            <option value="5">★★★★★ (5 Stars)</option>
                            <option value="4">★★★★☆ (4 Stars)</option>
                            <option value="3">★★★☆☆ (3 Stars)</option>
                            <option value="2">★★☆☆☆ (2 Stars)</option>
                            <option value="1">★☆☆☆☆ (1 Star)</option>
                        </select>
                        <span asp-validation-for="NewReview.Rating" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary btn-block w-100 font-weight-bold py-2">Submit for Review</button>
                </form>
            </div>
        </div>
    </div>
</div>
