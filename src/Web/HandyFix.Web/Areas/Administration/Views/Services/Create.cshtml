@model HandyFix.Web.ViewModels.Administration.Services.ServiceAdminInputModel
@{
    this.ViewData["Title"] = "Add New Service";
}

<!-- Breadcrumbs -->
<nav class="breadcrumb-nav mb-4 admin-header-row" aria-label="breadcrumb">
    <a asp-area="Administration" asp-controller="Dashboard" asp-action="Index">Admin</a>
    <span class="material-symbols-outlined breadcrumb-separator">chevron_right</span>
    <a asp-area="Administration" asp-controller="Services" asp-action="Index">Services</a>
    <span class="material-symbols-outlined breadcrumb-separator">chevron_right</span>
    <span class="breadcrumb-current">Add New Service</span>
</nav>

<!-- Page Header -->
<div class="mb-5">
    <h2 class="admin-page-title">Add New Service</h2>
    <p class="font-body-md text-on-surface-variant mt-1 admin-page-subtitle">Configure a new professional home service to offer to your clients.</p>
</div>

<!-- Form Content -->
<div class="mx-auto admin-form-container">
    <div class="rounded-xl shadow-sm p-5 p-md-5 admin-card">
        <form asp-area="Administration" asp-controller="Services" asp-action="Create" method="post" enctype="multipart/form-data" id="serviceForm" class="d-flex flex-column gap-5">
            <div class="row">
                <!-- Service Name -->
                <div class="col-md-6 form-group">
                    <label asp-for="Name" class="form-label font-label-sm text-on-surface-variant mb-2">Service Name</label>
                    <input asp-for="Name" class="form-control py-3 admin-form-control form-pad-standard" placeholder="e.g. Emergency Pipe Repair" required />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <!-- Category -->
                <div class="col-md-6 form-group">
                    <label asp-for="CategoryId" class="form-label font-label-sm text-on-surface-variant mb-2">Category Division</label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-control py-3 admin-form-control form-pad-standard" required>
                        <option value="">-- Choose Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Detailed Description -->
            <div class="form-group">
                <label asp-for="Description" class="form-label font-label-sm text-on-surface-variant mb-2">Detailed Description</label>
                <textarea asp-for="Description" class="form-control admin-form-control form-pad-standard resize-none" rows="4" placeholder="Describe the scope of work, tools included, and common issues resolved (minimum 20 characters)..." required></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row">
                <!-- Base Price -->
                <div class="col-md-6 form-group">
                    <label asp-for="BasePrice" class="form-label font-label-sm text-on-surface-variant mb-2">Base Price (£)</label>
                    <div class="position-relative">
                        <span class="position-absolute font-bold text-on-surface-variant admin-form-affix admin-form-affix-left">£</span>
                        <input asp-for="BasePrice" class="form-control py-3 admin-form-control form-control-price-affix" type="number" step="0.01" placeholder="0.00" required />
                    </div>
                    <span asp-validation-for="BasePrice" class="text-danger small"></span>
                </div>
                <!-- Duration -->
                <div class="col-md-6 form-group">
                    <label asp-for="EstimatedDurationMinutes" class="form-label font-label-sm text-on-surface-variant mb-2">Duration (Minutes)</label>
                    <div class="position-relative">
                        <input asp-for="EstimatedDurationMinutes" class="form-control py-3 admin-form-control form-control-duration-affix" type="number" placeholder="60" required />
                        <span class="position-absolute font-label-sm text-on-surface-variant admin-form-affix admin-form-affix-right">min</span>
                    </div>
                    <span asp-validation-for="EstimatedDurationMinutes" class="text-danger small"></span>
                </div>
            </div>

            <!-- Service Image Upload -->
            <div class="form-group">
                <label asp-for="ImageFile" class="form-label font-label-sm text-on-surface-variant mb-2">Service Image</label>
                <div class="d-flex flex-column gap-2">
                    <input asp-for="ImageFile" type="file" accept="image/*" class="form-control w-100 admin-form-control file-input-pad" />
                    <span class="font-label-sm text-on-surface-variant fs-11 admin-page-subtitle">Supported formats: JPEG, PNG, WEBP. Maximum file size: 5MB.</span>
                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="pt-4 d-flex flex-column flex-md-row align-items-center justify-content-end gap-3 form-actions-row">
                <a asp-area="Administration" asp-controller="Services" asp-action="Index" class="btn btn-outline font-button-text admin-btn-outline btn-py3-px8">Cancel</a>
                <button class="btn btn-primary font-button-text d-flex align-items-center justify-content-center gap-2 rounded-lg btn-py3-px8" type="submit">
                    <span class="material-symbols-outlined">save</span>
                    <span>Save Service</span>
                </button>
            </div>
        </form>
    </div>

    <!-- Contextual Help -->
    <div class="row pt-2">
        <div class="col-md-6 mb-3">
            <div class="p-4 d-flex align-items-start gap-3 h-100 help-card">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-secondary dim-40 tint-secondary help-card-icon">
                    <span class="material-symbols-outlined">info</span>
                </div>
                <div>
                    <h4 class="font-headline-sm text-primary mb-1 fs-15">Pricing Strategy</h4>
                    <p class="font-label-sm text-on-surface-variant mb-0 fs-13 lh-snug">Base prices should include initial consultation and travel within a standard service radius.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-3">
            <div class="p-4 d-flex align-items-start gap-3 h-100 help-card">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-on-tertiary-container dim-40 tint-success help-card-icon">
                    <span class="material-symbols-outlined">schedule</span>
                </div>
                <div>
                    <h4 class="font-headline-sm text-primary mb-1 fs-15">Time Buffer</h4>
                    <p class="font-label-sm text-on-surface-variant mb-0 fs-13 lh-snug">We automatically add a 15-minute buffer between bookings for travel and equipment setup.</p>
                </div>
            </div>
        </div>
    </div>
</div>
