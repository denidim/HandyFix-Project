@model IEnumerable<HandyFix.Web.ViewModels.Services.ServiceViewModel>
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Manage Services - Admin";
}

<div class="py-4 text-slate">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <div>
            <h1 class="font-weight-bold mb-0">Manage Services</h1>
            <p class="text-muted small mb-0">Add, edit, or delete HandyFix service offerings.</p>
        </div>
        <div>
            <a href="/Administration/Services/Create" class="btn btn-success font-weight-bold">+ Add Service</a>
            <a href="/Administration/Dashboard" class="btn btn-outline-secondary ml-2">Back</a>
        </div>
    </div>

    <div class="table-responsive bg-white border rounded shadow-sm">
        <table class="table table-hover table-striped mb-0 text-slate small">
            <thead>
                <tr>
                    <th>Service Name</th>
                    <th>Price</th>
                    <th>Estimated Duration</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var svc in Model)
                    {
                        <tr>
                            <td class="font-weight-bold">@svc.Name</td>
                            <td class="text-success font-weight-bold">£@svc.BasePrice.ToString("F2")</td>
                            <td>@svc.EstimatedDurationMinutes minutes</td>
                            <td class="text-right">
                                <a href="/Administration/Services/Edit/@svc.Id" class="btn btn-sm btn-outline-primary mr-1">Edit</a>
                                <form asp-area="Administration" asp-controller="Services" asp-action="Delete" asp-route-id="@svc.Id" method="post" class="d-inline-block" onsubmit="return confirm('Are you sure you want to delete this service?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center p-4 text-muted">No services found in database.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
