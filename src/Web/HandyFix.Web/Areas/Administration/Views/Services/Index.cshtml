@model IEnumerable<HandyFix.Web.ViewModels.Services.ServiceViewModel>
@{
    this.ViewData["Title"] = "Manage Services";

    var totalServices = Model.Count();
    var averagePrice = Model.Any() ? Model.Average(s => s.BasePrice) : 0;
    var totalCategories = Model.Any() ? Model.Select(s => s.CategorySlug).Distinct().Count() : 0;
}

<!-- Sticky Topbar Header -->
<div class="d-flex flex-col flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-4 admin-header-row">
    <div>
        <h1 class="admin-page-title">Manage Services</h1>
        <p class="font-label-sm text-on-surface-variant mt-1 admin-page-subtitle">Update, add, or remove items from your service catalog.</p>
    </div>
    <a asp-area="Administration" asp-controller="Services" asp-action="Create" class="btn btn-primary font-button-text d-flex align-items-center justify-content-center gap-2 w-100 w-md-auto rounded-lg btn-py3-px6">
        <span class="material-symbols-outlined">add</span>
        <span>Add Service</span>
    </a>
</div>

<!-- Quick Stats Bento-lite -->
<div class="bento-grid bento-grid-3 mb-5">
    <div class="glass-card p-4 rounded-xl d-flex align-items-center justify-content-between admin-stat-card">
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1">Total Services</p>
            <h3 class="font-headline-md mb-0 fs-headline-md font-bold text-primary">@totalServices</h3>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center text-secondary dim-48 tint-secondary">
            <span class="material-symbols-outlined">list_alt</span>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl d-flex align-items-center justify-content-between admin-stat-card">
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1">Average Price</p>
            <h3 class="font-headline-md mb-0 fs-headline-md font-bold text-primary">£@averagePrice.ToString("F2")</h3>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center text-on-tertiary-container dim-48 tint-success">
            <span class="material-symbols-outlined">payments</span>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl d-flex align-items-center justify-content-between admin-stat-card">
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1">Categories</p>
            <h3 class="font-headline-md mb-0 fs-headline-md font-bold text-primary">@totalCategories</h3>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center text-primary dim-48 tint-surface-high">
            <span class="material-symbols-outlined">category</span>
        </div>
    </div>
</div>

<!-- Services Table Container -->
<div class="rounded-xl overflow-hidden shadow-sm admin-card">
    <div class="px-4 py-3 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-4 admin-table-toolbar">
        <div class="position-relative max-w-sm w-100 admin-search-wrap">
            <span class="material-symbols-outlined position-absolute text-outline admin-search-icon">search</span>
            <input class="w-100 py-2 border rounded-lg outline-none font-body-md admin-search-input" placeholder="Search services..." type="text" id="services-search">
        </div>
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-outline d-flex align-items-center gap-2 admin-btn-compact admin-btn-outline">
                <span class="material-symbols-outlined fs-18">filter_list</span>
                <span>Filter</span>
            </button>
        </div>
    </div>

    <!-- Table Content -->
    <div class="table-responsive">
        <table class="table mb-0 text-left admin-table">
            <thead>
                <tr class="admin-table-head">
                    <th class="px-4 py-3 font-label-sm uppercase">Service Name</th>
                    <th class="px-4 py-3 font-label-sm uppercase">Category</th>
                    <th class="px-4 py-3 font-label-sm uppercase">Estimated Duration</th>
                    <th class="px-4 py-3 font-label-sm uppercase">Price</th>
                    <th class="px-4 py-3 font-label-sm uppercase text-right">Actions</th>
                </tr>
            </thead>
            <tbody id="services-table-body" class="bg-white">
                @if (Model.Any())
                {
                    @foreach (var svc in Model)
                    {
                        var categorySlug = svc.CategorySlug ?? "plumbing";
                        var icon = categorySlug == "plumbing" ? "plumbing" : "home_repair_service";
                        var categoryBadgeClass = categorySlug == "plumbing" ? "tint-secondary" : "tint-success";

                        <tr class="align-middle admin-table-row">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-lg d-flex align-items-center justify-content-center dim-40 tint-surface-high">
                                        <span class="material-symbols-outlined text-secondary">@icon</span>
                                    </div>
                                    <div>
                                        <p class="font-body-md font-bold mb-0 text-primary">@svc.Name</p>
                                        <p class="text-on-surface-variant mb-0 fs-12 service-desc-truncate">@svc.Description</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <span class="px-3 py-1 rounded-full font-label-sm @categoryBadgeClass">@categorySlug</span>
                            </td>
                            <td class="px-4 py-3 font-body-md text-primary">@svc.EstimatedDurationMinutes mins</td>
                            <td class="px-4 py-3 font-body-md font-bold text-secondary">£@svc.BasePrice.ToString("F2")</td>
                            <td class="px-4 py-3 text-right">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-area="Administration" asp-controller="Services" asp-action="Edit" asp-route-id="@svc.Id" class="p-2 text-on-surface-variant rounded-lg d-flex align-items-center justify-content-center dim-36 admin-btn-outline" title="Edit">
                                        <span class="material-symbols-outlined fs-20">edit</span>
                                    </a>
                                    <form asp-area="Administration" asp-controller="Services" asp-action="Delete" asp-route-id="@svc.Id" method="post" class="d-inline-block" onsubmit="return confirm('Are you sure you want to delete this service?');">
                                        <button type="submit" class="p-2 text-danger rounded-lg d-flex align-items-center justify-content-center dim-36 tint-error-soft border-error-soft" title="Delete">
                                            <span class="material-symbols-outlined fs-20">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center p-4 text-muted">No services found in database.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('services-search');
            const rows = document.querySelectorAll('#services-table-body tr');

            searchInput?.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase();
                rows.forEach(row => {
                    const text = row.innerText.toLowerCase();
                    row.style.display = text.includes(term) ? '' : 'none';
                });
            });
        });
    </script>
}
