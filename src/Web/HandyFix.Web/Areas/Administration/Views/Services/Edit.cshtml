@model HandyFix.Web.ViewModels.Administration.Services.ServiceAdminInputModel
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Edit Service - Admin";
    var categories = this.ViewData["Categories"] as SelectList;
}

<div class="py-4 max-width-600 mx-auto text-slate">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h1 class="font-weight-bold mb-0">Edit Service: @Model.Name</h1>
        <a href="/Administration/Services" class="btn btn-outline-secondary btn-sm">Cancel</a>
    </div>

    <div class="card p-4 rounded border bg-white shadow-sm">
        <form asp-area="Administration" asp-controller="Services" asp-action="Edit" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="form-group mb-3">
                <label asp-for="Name" class="form-label font-weight-bold small">Service Name</label>
                <input asp-for="Name" class="form-control" required />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CategoryId" class="form-label font-weight-bold small">Category Division</label>
                <select asp-for="CategoryId" asp-items="categories" class="form-control" required></select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Description" class="form-label font-weight-bold small">Detailed Description</label>
                <textarea asp-for="Description" class="form-control" rows="4" required></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="BasePrice" class="form-label font-weight-bold small">Base Price (£)</label>
                    <input asp-for="BasePrice" class="form-control" type="number" step="0.01" required />
                    <span asp-validation-for="BasePrice" class="text-danger small"></span>
                </div>
                <div class="col-md-6 form-group mb-3">
                    <label asp-for="EstimatedDurationMinutes" class="form-label font-weight-bold small">Duration (Minutes)</label>
                    <input asp-for="EstimatedDurationMinutes" class="form-control" type="number" step="1" required />
                    <span asp-validation-for="EstimatedDurationMinutes" class="text-danger small"></span>
                </div>
            </div>

            <div class="form-group form-check mb-4">
                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                <label asp-for="IsActive" class="form-check-label font-weight-bold small">Is Active Service</label>
            </div>

            <button type="submit" class="btn btn-primary btn-block w-100 font-weight-bold py-2">Update Service</button>
        </form>
    </div>
</div>
