@model HandyFix.Web.ViewModels.Booking.BookingListViewModel
@{
    this.ViewData["Title"] = "Manage Bookings";

    var bookings = Model.Bookings;
}

@functions {
    bool NextDescending(HandyFix.Web.ViewModels.Booking.BookingSortField field)
    {
        return this.Model.SortField == field ? !this.Model.Descending : false;
    }
}

<!-- Sticky Header -->
<div class="d-flex flex-col flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-4 admin-header-row">
    <div>
        <h1 class="admin-page-title">Bookings Management</h1>
        <p class="font-label-sm text-on-surface-variant mt-1 admin-page-subtitle">Track and manage service appointments</p>
    </div>
    <div class="d-flex align-items-center gap-3">
        <form method="get" asp-area="Administration" asp-controller="Bookings" asp-action="Index" class="m-0">
            <input type="hidden" name="sortField" value="@Model.SortField" />
            <input type="hidden" name="descending" value="@(Model.Descending.ToString())" />
            <select name="status" class="admin-status-filter font-body-md" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                @foreach (var statusOption in Model.StatusOptions)
                {
                    <option value="@statusOption" selected="@(Model.StatusFilter == statusOption)">@statusOption</option>
                }
            </select>
        </form>
        <div class="position-relative max-w-sm w-100 admin-search-wrap">
            <span class="material-symbols-outlined position-absolute text-outline admin-search-icon">search</span>
            <input class="w-100 py-2 border rounded-lg outline-none font-body-md admin-search-input" placeholder="Search Ref ID or Name..." type="text" id="bookings-search">
        </div>
    </div>
</div>

<!-- Quick Stats -->
<div class="bento-grid bento-grid-3 mb-5">
    <div class="glass-card p-4 rounded-xl d-flex align-items-center justify-content-between admin-stat-card">
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1">Today's Appointments</p>
            <h3 class="font-headline-md mb-0 fs-headline-md font-bold text-primary">@Model.TodaysAppointmentsCount</h3>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center text-secondary dim-48 tint-secondary">
            <span class="material-symbols-outlined">calendar_today</span>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl d-flex align-items-center justify-content-between admin-stat-card">
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1">Pending Approval</p>
            <h3 class="font-headline-md mb-0 text-secondary fs-headline-md font-bold">@Model.PendingApprovalCount</h3>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center text-secondary dim-48 tint-secondary">
            <span class="material-symbols-outlined">pending_actions</span>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl d-flex align-items-center justify-content-between admin-stat-card">
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1">Monthly Revenue</p>
            <h3 class="font-headline-md mb-0 fs-headline-md font-bold text-primary">£@Model.MonthlyRevenue.ToString("N2")</h3>
        </div>
        <div class="rounded-circle d-flex align-items-center justify-content-center text-on-tertiary-container dim-48 tint-success">
            <span class="material-symbols-outlined">payments</span>
        </div>
    </div>
</div>

<!-- Bookings List Table -->
<div class="rounded-xl overflow-hidden shadow-sm admin-card">
    <div class="px-4 py-3 d-flex align-items-center justify-content-between admin-table-toolbar">
        <h3 class="font-headline-sm text-primary mb-0">All Bookings</h3>
    </div>

    <div class="table-responsive">
        <table class="w-full text-left table mb-0 admin-table">
            <thead>
                <tr class="admin-table-head">
                    <th class="px-4 py-3 font-label-sm uppercase">Ref ID</th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Bookings" asp-action="Index"
                           asp-route-sortField="CustomerName" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Booking.BookingSortField.CustomerName)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.CustomerName ? "active" : "")">
                            Customer
                            @if (Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.CustomerName)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Bookings" asp-action="Index"
                           asp-route-sortField="AppointmentTime" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Booking.BookingSortField.AppointmentTime)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.AppointmentTime ? "active" : "")">
                            Scheduled Date
                            @if (Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.AppointmentTime)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Bookings" asp-action="Index"
                           asp-route-sortField="CreatedOn" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Booking.BookingSortField.CreatedOn)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.CreatedOn ? "active" : "")">
                            Submitted On
                            @if (Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.CreatedOn)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase">Amount</th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Bookings" asp-action="Index"
                           asp-route-sortField="Status" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Booking.BookingSortField.Status)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.Status ? "active" : "")">
                            Booking Status
                            @if (Model.SortField == HandyFix.Web.ViewModels.Booking.BookingSortField.Status)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase">Payment</th>
                    <th class="px-4 py-3 font-label-sm uppercase text-right">Actions</th>
                </tr>
            </thead>
            <tbody id="bookings-table-body" class="bg-white">
                @if (bookings.Any())
                {
                    @foreach (var booking in bookings)
                    {
                        var initials = $"{booking.CustomerFirstName[0]}{booking.CustomerLastName[0]}";

                        var statusBadgeClass = booking.StatusName == "Pending" ? "tint-neutral" :
                                           booking.StatusName == "Cancelled" ? "tint-error" :
                                           booking.StatusName == "Completed" ? "tint-success" :
                                           "tint-secondary";

                        var paymentText = booking.PaymentStatus == "DepositPaid" ? "Paid" : "Unpaid";
                        var paymentDotClass = booking.PaymentStatus == "DepositPaid" ? "payment-dot-paid" : "payment-dot-unpaid";
                        var paymentTextClass = booking.PaymentStatus == "DepositPaid" ? "text-on-tertiary-container" : "text-outline";

                        <tr class="align-middle admin-table-row">
                            <td class="px-4 py-3 font-body-md font-bold text-secondary select-all">#@booking.Id.ToString().Substring(0, 8).ToUpper()</td>
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center text-on-secondary-container font-bold fs-11 avatar-badge dim-32 tint-secondary-fixed">
                                        @initials.ToUpper()
                                    </div>
                                    <div>
                                        <p class="font-body-md font-bold mb-0 text-primary">@booking.CustomerFirstName @booking.CustomerLastName</p>
                                        <p class="text-on-surface-variant mb-0 fs-11">@booking.Address</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 font-body-md text-primary">@booking.ScheduledTime.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-3">
                                <p class="font-body-md text-primary mb-0">@booking.CreatedOn.ToLocalTime().ToString("MMM dd, yyyy")</p>
                                <p class="text-on-surface-variant mb-0 fs-11">@booking.CreatedOn.ToLocalTime().ToString("hh:mm tt")</p>
                            </td>
                            <td class="px-4 py-3 font-body-md font-bold text-primary">£@booking.TotalAmount.ToString("F2")</td>
                            <td class="px-4 py-3">
                                <span class="px-3 py-1 rounded-full font-label-sm font-bold @statusBadgeClass">@booking.StatusName</span>
                            </td>
                            <td class="px-4 py-3">
                                <span class="d-flex align-items-center gap-1.5 font-label-sm font-bold @paymentTextClass">
                                    <span class="rounded-circle payment-dot @paymentDotClass"></span>
                                    <span>@paymentText</span>
                                </span>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a asp-area="Administration" asp-controller="Bookings" asp-action="Details" asp-route-id="@booking.Id" class="btn btn-secondary font-button-text admin-btn-compact">Details</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center p-4 text-muted">No appointments booked yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('bookings-search');
            const rows = document.querySelectorAll('#bookings-table-body tr');

            searchInput?.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase();
                rows.forEach(row => {
                    const text = row.innerText.toLowerCase();
                    row.style.display = text.includes(term) ? '' : 'none';
                });
            });
        });
    </script>
}
