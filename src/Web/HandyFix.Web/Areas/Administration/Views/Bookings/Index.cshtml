@model IEnumerable<HandyFix.Web.ViewModels.Booking.BookingDetailsViewModel>
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Manage Bookings - Admin";
}

<div class="py-4 text-slate">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <h1 class="font-weight-bold mb-0">Manage Bookings</h1>
        <a href="/Administration/Dashboard" class="btn btn-outline-secondary btn-sm">← Back to Dashboard</a>
    </div>

    <div class="table-responsive bg-white border rounded shadow-sm">
        <table class="table table-hover table-striped mb-0 text-slate small">
            <thead>
                <tr>
                    <th>Ref ID</th>
                    <th>Customer Name</th>
                    <th>Scheduled Date</th>
                    <th>Total Amount</th>
                    <th>Booking Status</th>
                    <th>Payment Status</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var booking in Model)
                    {
                        <tr>
                            <td class="font-weight-bold text-truncate select-all" style="max-width: 100px;">@booking.Id</td>
                            <td>@booking.CustomerFirstName @booking.CustomerLastName</td>
                            <td>@booking.ScheduledTime.ToString("dd MMM yyyy 'at' HH:mm")</td>
                            <td>£@booking.TotalAmount.ToString("F2")</td>
                            <td>
                                <span class="badge @(booking.StatusName == "Pending" ? "bg-warning" : booking.StatusName == "Approved" ? "bg-info" : booking.StatusName == "Completed" ? "bg-success" : "bg-secondary")">
                                    @booking.StatusName
                                </span>
                            </td>
                            <td>
                                <span class="badge @(booking.PaymentStatus == "DepositPaid" ? "bg-success" : "bg-secondary")">
                                    @booking.PaymentStatus
                                </span>
                            </td>
                            <td class="text-right">
                                <a href="/Administration/Bookings/Details/@booking.Id" class="btn btn-sm btn-primary">Details / Manage</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center p-4 text-muted">No appointments booked yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
