@model HandyFix.Web.ViewModels.Reviews.ReviewListViewModel
@{
    this.ViewData["Title"] = "Moderate Reviews";

    var reviews = Model.Reviews;
    var pendingReviews = Model.PendingCount;
    var averageRating = Model.AverageRating;
    var totalPublished = Model.TotalPublished;
    var approvalRate = Model.ApprovalRate;
    var flaggedReviews = 0; // Simulated field or 0 as database fallback
}

@functions {
    bool NextDescending(HandyFix.Web.ViewModels.Reviews.ReviewSortField field)
    {
        return this.Model.SortField == field ? !this.Model.Descending : false;
    }
}

<!-- Top Header Context -->
<div class="d-flex flex-col flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-4 admin-header-row">
    <div class="d-flex align-items-center gap-3">
        <h1 class="admin-page-title">Review Moderation</h1>
        <span class="px-3 py-1 text-secondary font-bold font-label-sm rounded-full tint-secondary border-secondary-soft">
            @pendingReviews Pending
        </span>
    </div>
    <div class="d-flex align-items-center gap-3">
        <form method="get" asp-area="Administration" asp-controller="Reviews" asp-action="Index" class="m-0">
            <input type="hidden" name="sortField" value="@Model.SortField" />
            <input type="hidden" name="descending" value="@(Model.Descending.ToString())" />
            <select name="status" class="admin-status-filter font-body-md" onchange="this.form.submit()">
                <option value="">All Statuses</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
            </select>
        </form>
        <a asp-area="Administration" asp-controller="Reviews" asp-action="Index" class="btn btn-primary font-button-text d-flex align-items-center justify-content-center gap-2 w-100 w-md-auto rounded-lg btn-py3-px6">
            <span class="material-symbols-outlined">refresh</span>
            <span>Refresh List</span>
        </a>
    </div>
</div>

<!-- Summary Stats (Bento Style) -->
<div class="bento-grid bento-grid-4 mb-5">
    <div class="glass-card p-4 rounded-xl admin-stat-card">
        <p class="font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Average Rating</p>
        <div class="d-flex align-items-end gap-2">
            <p class="font-headline-lg mb-0 fs-headline-lg font-bold text-primary">@averageRating.ToString("0.0")</p>
            <div class="d-flex text-secondary mb-2">
                @for (int i = 1; i <= 5; i++)
                {
                    var isFilled = i <= Math.Round(averageRating);
                    var icon = isFilled ? "star" : "star_outline";
                    <span class="material-symbols-outlined fs-16 @(isFilled ? "icon-fill" : "icon-unfill")">@icon</span>
                }
            </div>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl admin-stat-card">
        <p class="font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Total Published</p>
        <p class="font-headline-lg mb-0 fs-headline-lg font-bold text-primary">@totalPublished</p>
    </div>

    <div class="glass-card p-4 rounded-xl tint-secondary-faint border-secondary-soft">
        <p class="text-secondary font-label-sm mb-1 uppercase tracking-wider">Approval Rate</p>
        <p class="font-headline-lg mb-0 fs-headline-lg font-bold text-secondary">@approvalRate%</p>
    </div>

    <div class="glass-card p-4 rounded-xl admin-stat-card">
        <p class="font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Flagged Reviews</p>
        <p class="font-headline-lg mb-0 text-danger fs-headline-lg font-bold">@flaggedReviews</p>
    </div>
</div>

<!-- Moderation Table Container -->
<div class="rounded-xl overflow-hidden shadow-sm admin-card">
    <div class="table-responsive">
        <table class="table mb-0 text-left admin-table">
            <thead>
                <tr class="admin-table-head">
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Reviews" asp-action="Index"
                           asp-route-sortField="CustomerName" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Reviews.ReviewSortField.CustomerName)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Reviews.ReviewSortField.CustomerName ? "active" : "")">
                            Customer
                            @if (Model.SortField == HandyFix.Web.ViewModels.Reviews.ReviewSortField.CustomerName)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Reviews" asp-action="Index"
                           asp-route-sortField="Rating" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Reviews.ReviewSortField.Rating)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Reviews.ReviewSortField.Rating ? "active" : "")">
                            Rating
                            @if (Model.SortField == HandyFix.Web.ViewModels.Reviews.ReviewSortField.Rating)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase w-50">Comment</th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Reviews" asp-action="Index"
                           asp-route-sortField="CreatedOn" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Reviews.ReviewSortField.CreatedOn)" asp-route-status="@Model.StatusFilter"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Reviews.ReviewSortField.CreatedOn ? "active" : "")">
                            Date
                            @if (Model.SortField == HandyFix.Web.ViewModels.Reviews.ReviewSortField.CreatedOn)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="bg-white">
                @if (reviews.Any())
                {
                    @foreach (var review in reviews)
                    {
                        var names = review.CustomerName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = names.Length > 1 ? $"{names[0][0]}{names[1][0]}" : $"{names[0][0]}";

                        <tr class="align-middle admin-table-row">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center font-bold dim-32 tint-primary-fixed-dim fs-11">
                                        @initials.ToUpper()
                                    </div>
                                    <div>
                                        <p class="font-body-md font-bold mb-0 text-primary">@review.CustomerName</p>
                                        <p class="text-on-surface-variant mb-0 fs-11">Verified Client</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <div class="d-flex text-secondary">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        var isFilled = i <= review.Rating;
                                        var icon = isFilled ? "star" : "star_outline";
                                        <span class="material-symbols-outlined fs-16 @(isFilled ? "icon-fill" : "icon-unfill")">@icon</span>
                                    }
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <p class="font-body-md text-on-surface mb-0 italic message-snippet-truncate">"@review.Comment"</p>
                            </td>
                            <td class="px-4 py-3 font-body-md text-on-surface-variant">@review.CreatedOn.ToString("MMM dd, yyyy")</td>
                            <td class="px-4 py-3 text-right">
                                <div class="d-flex justify-content-end gap-2 align-items-center">
                                    @if (!review.IsApproved)
                                    {
                                        <form asp-area="Administration" asp-controller="Reviews" asp-action="Approve" asp-route-id="@review.Id" method="post" class="d-inline-block">
                                            <button type="submit" class="btn btn-sm d-flex align-items-center gap-1 font-label-sm admin-btn-compact tint-success btn-no-border">
                                                <span class="material-symbols-outlined fs-16">check_circle</span>
                                                <span>Approve</span>
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 font-label-sm font-bold rounded-full tint-secondary-soft">Approved</span>
                                    }

                                    <form asp-area="Administration" asp-controller="Reviews" asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline-block" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                        <button type="submit" class="p-2 text-danger rounded-lg d-flex align-items-center justify-content-center dim-36 tint-error-soft border-error-soft" title="Delete Review">
                                            <span class="material-symbols-outlined fs-20">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center p-4 text-muted">No reviews submitted yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
