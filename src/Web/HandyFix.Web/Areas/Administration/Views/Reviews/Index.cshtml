@model IEnumerable<HandyFix.Web.ViewModels.Reviews.ReviewViewModel>
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = "Moderate Reviews - Admin";
}

<div class="py-4 text-slate">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <div>
            <h1 class="font-weight-bold mb-0">Review Moderation</h1>
            <p class="text-muted small mb-0">Approve or hide customer submissions for the home page carousel.</p>
        </div>
        <a href="/Administration/Dashboard" class="btn btn-outline-secondary">Back</a>
    </div>

    <div class="table-responsive bg-white border rounded shadow-sm">
        <table class="table table-hover table-striped mb-0 text-slate small">
            <thead>
                <tr>
                    <th>Customer Name</th>
                    <th>Rating</th>
                    <th>Comment</th>
                    <th>Date</th>
                    <th class="text-right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    @foreach (var review in Model)
                    {
                        <tr>
                            <td class="font-weight-bold">@review.CustomerName</td>
                            <td class="text-warning">
                                @for (int i = 0; i < review.Rating; i++)
                                {
                                    <span>★</span>
                                }
                            </td>
                            <td class="text-muted text-truncate" style="max-width: 250px;">@review.Comment</td>
                            <td>@review.CreatedOn.ToString("dd MMM yyyy")</td>
                            <td class="text-right">
                                @if (!review.IsApproved)
                                {
                                    <form asp-area="Administration" asp-controller="Reviews" asp-action="Approve" asp-route-id="@review.Id" method="post" class="d-inline-block">
                                        <button type="submit" class="btn btn-sm btn-success mr-1">Approve</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="badge bg-success mr-2 py-1 px-2">Approved</span>
                                }
                                <form asp-area="Administration" asp-controller="Reviews" asp-action="Delete" asp-route-id="@review.Id" method="post" class="d-inline-block" onsubmit="return confirm('Are you sure you want to delete this review?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete / Hide</button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center p-4 text-muted">No reviews submitted yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
