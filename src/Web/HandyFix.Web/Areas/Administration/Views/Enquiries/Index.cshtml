@model HandyFix.Web.ViewModels.Administration.Enquiries.EnquiryListViewModel
@{
    this.ViewData["Title"] = "Client Enquiries";
    var inquiries = Model.Inquiries;
    var totalEnquiries = inquiries.Count();
}

@functions {
    bool NextDescending(HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField field)
    {
        return this.Model.SortField == field ? !this.Model.Descending : false;
    }
}

<!-- Top Header Context -->
<div class="d-flex flex-col flex-md-row justify-content-between align-items-start align-items-md-center mb-5 gap-4 admin-header-row">
    <div class="d-flex align-items-center gap-3">
        <h1 class="admin-page-title">Client Enquiries</h1>
        <span class="px-3 py-1 text-secondary font-bold font-label-sm rounded-full tint-secondary border-secondary-soft">
            @totalEnquiries Total
        </span>
    </div>
    <div class="position-relative max-w-sm w-100 admin-search-wrap">
        <span class="material-symbols-outlined position-absolute text-outline admin-search-icon">search</span>
        <input class="w-100 py-2 border rounded-lg outline-none font-body-md admin-search-input" placeholder="Search enquiries..." type="text" id="enquiries-search">
    </div>
</div>

<!-- Bento-Style Table Container -->
<div class="rounded-xl overflow-hidden shadow-sm admin-card">
    <div class="table-responsive">
        <table class="table mb-0 text-left admin-table">
            <thead>
                <tr class="admin-table-head">
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Enquiries" asp-action="Index"
                           asp-route-sortField="Name" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField.Name)"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField.Name ? "active" : "")">
                            Client Details
                            @if (Model.SortField == HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField.Name)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase w-50">Message Snippet</th>
                    <th class="px-4 py-3 font-label-sm uppercase">
                        <a asp-area="Administration" asp-controller="Enquiries" asp-action="Index"
                           asp-route-sortField="CreatedOn" asp-route-descending="@this.NextDescending(HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField.CreatedOn)"
                           class="admin-sort-link @(Model.SortField == HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField.CreatedOn ? "active" : "")">
                            Submission Date
                            @if (Model.SortField == HandyFix.Web.ViewModels.Administration.Enquiries.InquirySortField.CreatedOn)
                            {
                                <span class="material-symbols-outlined fs-16">@(Model.Descending ? "arrow_downward" : "arrow_upward")</span>
                            }
                        </a>
                    </th>
                    <th class="px-4 py-3 font-label-sm uppercase text-right">Actions</th>
                </tr>
            </thead>
            <tbody id="enquiries-table-body" class="bg-white">
                @if (inquiries.Any())
                {
                    @foreach (var inquiry in inquiries)
                    {
                        var names = inquiry.Name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                        var initials = names.Length > 1 ? $"{names[0][0]}{names[1][0]}" : $"{names[0][0]}";

                        <tr class="align-middle admin-table-row">
                            <td class="px-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="rounded-circle d-flex align-items-center justify-content-center font-bold flex-shrink-0 dim-40 tint-primary-fixed-dim fs-12">
                                        @initials.ToUpper()
                                    </div>
                                    <div>
                                        <p class="font-body-md font-bold mb-0 text-primary">@inquiry.Name</p>
                                        <p class="text-on-surface-variant mb-0 select-all fs-11">@inquiry.Email</p>
                                        <p class="text-on-surface-variant mb-0 select-all fs-11 font-medium">@inquiry.PhoneNumber</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3">
                                <p class="font-body-md text-on-surface mb-0 italic message-snippet-truncate">"@inquiry.Message"</p>
                            </td>
                            <td class="px-4 py-3">
                                <p class="font-body-md text-primary mb-0">@inquiry.CreatedOn.ToString("MMM dd, yyyy")</p>
                                <p class="text-on-surface-variant mb-0 fs-11">@inquiry.CreatedOn.ToString("hh:mm tt")</p>
                            </td>
                            <td class="px-4 py-3 text-right">
                                <a asp-area="Administration" asp-controller="Enquiries" asp-action="Details" asp-route-id="@inquiry.Id" class="btn btn-sm d-inline-flex align-items-center gap-1 font-label-sm admin-btn-compact tint-secondary-soft btn-no-border">
                                    <span class="material-symbols-outlined fs-16">visibility</span>
                                    <span>Details</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center p-4 text-muted">No enquiries received yet.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Contextual Stats Summary (Bento Grid elements) -->
<div class="bento-grid bento-grid-3 mt-5">
    <div class="glass-card p-4 rounded-xl d-flex align-items-center gap-3 admin-stat-card">
        <div class="rounded-circle d-flex align-items-center justify-content-center text-secondary flex-shrink-0 dim-48 tint-secondary">
            <span class="material-symbols-outlined fs-24">speed</span>
        </div>
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Avg. Response Time</p>
            <p class="font-headline-sm mb-0 fs-18 font-bold text-primary">2.4 Hours</p>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl d-flex align-items-center gap-3 admin-stat-card">
        <div class="rounded-circle d-flex align-items-center justify-content-center text-on-tertiary-container flex-shrink-0 dim-48 tint-success">
            <span class="material-symbols-outlined fs-24 icon-fill">check_circle</span>
        </div>
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Resolution Rate</p>
            <p class="font-headline-sm mb-0 fs-18 font-bold text-primary">94%</p>
        </div>
    </div>

    <div class="glass-card p-4 rounded-xl d-flex align-items-center gap-3 admin-stat-card">
        <div class="rounded-circle d-flex align-items-center justify-content-center text-danger flex-shrink-0 dim-48 tint-error-soft">
            <span class="material-symbols-outlined fs-24">warning</span>
        </div>
        <div>
            <p class="font-label-sm text-on-surface-variant mb-1 uppercase tracking-wider">Urgent Requests</p>
            <p class="font-headline-sm mb-0 fs-18 font-bold text-danger">3 Tickets</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const searchInput = document.getElementById('enquiries-search');
            const rows = document.querySelectorAll('#enquiries-table-body tr');

            searchInput?.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase();
                rows.forEach(row => {
                    const text = row.innerText.toLowerCase();
                    row.style.display = text.includes(term) ? '' : 'none';
                });
            });
        });
    </script>
}
