@model HandyFix.Web.ViewModels.Administration.Enquiries.EnquiryViewModel
@{
    this.Layout = "_Layout";
    this.ViewData["Title"] = $"Enquiry Details - {Model.Name}";
}

<div class="py-4 text-slate">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
        <div>
            <h1 class="font-weight-bold mb-0">Enquiry Details</h1>
            <p class="text-muted small mb-0">Submitted on @Model.CreatedOn.ToString("dd MMM yyyy 'at' HH:mm")</p>
        </div>
        <a href="/Administration/Enquiries" class="btn btn-outline-secondary btn-sm">← Back to List</a>
    </div>

    <div class="row">
        <!-- Message Details -->
        <div class="col-lg-8 mb-4">
            <div class="card p-4 rounded border mb-4 bg-white shadow-sm">
                <h4 class="font-weight-bold text-slate mb-3 border-bottom pb-2">Client Message</h4>
                <div class="row mb-3 small">
                    <div class="col-sm-3 font-weight-bold">Client Name:</div>
                    <div class="col-sm-9">@Model.Name</div>
                </div>
                <div class="row mb-3 small">
                    <div class="col-sm-3 font-weight-bold">Email:</div>
                    <div class="col-sm-9 select-all">@Model.Email</div>
                </div>
                <div class="row mb-3 small">
                    <div class="col-sm-3 font-weight-bold">Phone Number:</div>
                    <div class="col-sm-9 select-all">@Model.PhoneNumber</div>
                </div>
                <div class="row mb-3 small">
                    <div class="col-sm-3 font-weight-bold">Inquiry Message:</div>
                    <div class="col-sm-9 text-muted text-justify" style="white-space: pre-wrap;">@Model.Message</div>
                </div>
            </div>

            <!-- Uploaded Images -->
            @if (Model.ImageUrls != null && Model.ImageUrls.Any())
            {
                <div class="card p-4 rounded border bg-white mb-4 shadow-sm">
                    <h4 class="font-weight-bold text-slate mb-3 border-bottom pb-2">Photos Attached by Client</h4>
                    <div class="row">
                        @foreach (var url in Model.ImageUrls)
                        {
                            <div class="col-sm-4 mb-3">
                                <a href="@url" target="_blank">
                                    <img src="@url" class="img-thumbnail img-fluid rounded hover-grow" alt="Attachment" style="max-height: 200px; object-fit: cover; width: 100%;" />
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Controls Sidebar -->
        <div class="col-lg-4">
            <div class="card p-4 rounded border bg-light shadow-sm text-center">
                <h4 class="font-weight-bold text-slate mb-3 border-bottom pb-2">Enquiry Actions</h4>
                <a href="mailto:@Model.Email?subject=Re:%20HandyFix%20Enquiry" class="btn btn-primary btn-block w-100 mb-3 py-2 font-weight-bold">📧 Reply via Email</a>
                <a href="tel:@Model.PhoneNumber" class="btn btn-outline-primary btn-block w-100 mb-4 py-2 font-weight-bold">📞 Call Customer</a>
                
                <form asp-area="Administration" asp-controller="Enquiries" asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this enquiry?');">
                    <button type="submit" class="btn btn-outline-danger btn-block w-100">Delete Enquiry</button>
                </form>
            </div>
        </div>
    </div>
</div>
